page {
  min-height: 100%;
  background: #071016;
  color: #061d1f;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

view,
text,
input,
picker,
textarea,
button {
  box-sizing: border-box;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.hero-title,
.seal,
.avatar,
.day-master,
.qimen-seal,
.focus-seal,
.section-title {
  font-family: "Kaiti SC", "STKaiti", "KaiTi", "Songti SC", "SimSun", serif;
}

.page {
  position: relative;
  z-index: 1;
  min-height: 100vh;
  padding: 24rpx 22rpx calc(42rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 88% 2%, rgba(30, 105, 132, .16), transparent 30%),
    radial-gradient(circle at 6% 14%, rgba(232, 201, 138, .08), transparent 34%),
    linear-gradient(180deg, #071016 0%, #0a1d28 42%, #edf3f4 42%, #e9eff1 100%);
}

.section {
  position: relative;
  z-index: 1;
  margin-bottom: 22rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(27, 107, 133, .16);
  border-radius: 12rpx;
  background: rgba(249, 252, 252, .94);
  box-shadow: 0 8rpx 18rpx rgba(0, 0, 0, .05);
}

.section-title {
  margin-bottom: 14rpx;
  color: #071823;
  font-size: 32rpx;
  font-weight: 800;
  letter-spacing: 0;
  line-height: 1.25;
}

.section-kicker {
  display: inline-flex;
  margin-bottom: 12rpx;
  padding: 5rpx 12rpx;
  border: 1rpx solid rgba(27, 107, 133, .14);
  border-radius: 999rpx;
  background: rgba(27, 107, 133, .08);
  color: #28515f;
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 0;
  line-height: 1.35;
}

.muted {
  color: #405b64;
  font-size: 26rpx;
  line-height: 1.65;
}

.field {
  margin-bottom: 22rpx;
}

.label {
  display: block;
  margin-bottom: 10rpx;
  color: #183742;
  font-size: 25rpx;
  font-weight: 800;
}

input,
picker,
textarea {
  width: 100%;
  border: 1rpx solid rgba(27, 107, 133, .22);
  border-radius: 10rpx;
  background: rgba(255, 255, 255, .90);
  color: #071823;
  font-size: 29rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, .78);
}

input,
picker {
  height: 82rpx;
  padding: 0 22rpx;
  line-height: 82rpx;
}

textarea {
  min-height: 144rpx;
  padding: 18rpx 22rpx;
  line-height: 1.55;
}

button {
  min-height: 78rpx;
  margin: 0;
  border-radius: 10rpx;
  font-size: 28rpx;
  font-weight: 800;
}

button::after {
  border: 0;
}

button.primary {
  margin-top: 16rpx;
  border: 1rpx solid rgba(5, 43, 42, .34);
  background: #1b6b85;
  color: #f8fffc;
  line-height: 86rpx;
  box-shadow: 0 6rpx 12rpx rgba(8, 82, 76, .14);
}

button.primary:active {
  background: #14566d;
  transform: translateY(1rpx);
}

button.secondary {
  border: 1rpx solid rgba(27, 107, 133, .24);
  background: rgba(235, 243, 245, .88);
  color: #163947;
  line-height: 76rpx;
}

button.secondary:active {
  background: rgba(220, 237, 233, .88);
}

button[disabled] {
  opacity: .48;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  max-width: 100%;
  padding: 8rpx 16rpx;
  border: 1rpx solid rgba(27, 107, 133, .16);
  border-radius: 999rpx;
  background: rgba(27, 107, 133, .08);
  color: #1f5b70;
  font-size: 24rpx;
  font-weight: 700;
}

.result-card {
  margin-top: 22rpx;
  padding: 22rpx;
  border: 1rpx solid rgba(27, 107, 133, .16);
  border-radius: 12rpx;
  background: rgba(239, 247, 249, .88);
}

.result-line {
  margin-bottom: 12rpx;
  color: #163947;
  font-size: 27rpx;
  line-height: 1.68;
}

.disclaimer {
  margin-top: 18rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(126, 98, 42, .22);
  border-radius: 14rpx;
  background: rgba(250, 246, 232, .72);
  color: #59451d;
  font-size: 24rpx;
  line-height: 1.68;
}
