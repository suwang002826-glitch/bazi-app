<view class="page liuyao-page liuyao-result-page">
  <x-pattern />

  <view class="result-topbar">
    <view class="back-button" bindtap="goBack">‹</view>
    <view class="result-title">六爻排盘</view>
    <view class="more-button">•••</view>
  </view>

  <view wx:if="{{!result}}" class="empty-state">
    <view class="empty-title">暂无六爻结果</view>
    <view class="empty-copy">请先完成一次起卦，再查看卦象与断事结果。</view>
    <button bindtap="goBack">返回起卦</button>
  </view>

  <view wx:else class="section result-panel liuyao-result-shell">
    <view class="result-head">
      <view>
        <view class="section-kicker">断事参考</view>
        <view class="section-title">{{result.hexagramName}}</view>
      </view>
      <view class="focus-seal">{{result.focus}}</view>
    </view>
    <view class="muted">所问：{{result.question}} · {{result.category}} · {{result.method}}</view>
    <view class="ritual-summary">
      <view class="ritual-summary-title">{{result.ritual.title}}</view>
      <view class="muted">{{result.ritual.castTime}} · {{result.ritual.method}}</view>
      <view class="ritual-rule-row">
        <text class="ritual-rule" wx:for="{{result.ritual.rules}}" wx:key="*this">{{item}}</text>
      </view>
      <view class="muted">{{result.ritual.text}}</view>
    </view>
    <view class="hex-meta">
      <view><text>本卦</text><text>{{result.hexagramName}}</text></view>
      <view><text>变卦</text><text>{{result.changedName}}</text></view>
      <view><text>卦宫</text><text>{{result.upperTrigram}}上 {{result.lowerTrigram}}下 · {{result.palace}} {{result.palaceElement}}局</text></view>
      <view><text>月日</text><text>月建 {{result.dateContext.month}} · 日辰 {{result.dateContext.day}}</text></view>
      <view><text>旬空</text><text>{{result.dateContext.voidText}}</text></view>
      <view><text>动爻</text><text>{{result.movingSummary}}</text></view>
      <view class="wide"><text>重点</text><text>{{result.focusLine}}</text></view>
    </view>
    <view class="hexagram-plate">
      <view class="hexagram-title-row">
        <view>
          <view class="hexagram-title">六神 {{result.hexagramName}}（{{result.palaceLabel}}）</view>
          <view class="hexagram-sub">{{result.upperTrigram}}上 {{result.lowerTrigram}}下 · {{result.palaceElement}}局</view>
        </view>
        <view>
          <view class="hexagram-title">{{result.changedName}}（{{result.changedPalaceLabel}}）</view>
          <view class="hexagram-sub">变卦</view>
        </view>
      </view>
      <view class="hexagram-lines">
        <view class="hexagram-line" wx:for="{{result.displayLines}}" wx:key="position">
          <view wx:if="{{item.fuShenText}}" class="fu-shen-row">↑ 伏神：{{item.fuShenText}}</view>
          <view class="hex-line-side base-side">
            <view class="hex-line-main">
              <text class="hex-spirit">{{item.base.spirit}}</text>
              <text class="hex-kin">{{item.base.naText}}</text>
              <view class="hex-mark {{item.base.value === 1 ? 'yang' : 'yin'}}"></view>
              <text wx:if="{{item.base.role}}" class="hex-role">{{item.base.role}}</text>
              <text wx:if="{{item.movingMark}}" class="hex-moving">{{item.movingMark}}</text>
            </view>
          </view>
          <view class="hex-change">{{item.changeText}}</view>
          <view class="hex-line-side changed-side">
            <text class="hex-kin">{{item.changed.naText}}</text>
            <view class="hex-mark {{item.changed.value === 1 ? 'yang' : 'yin'}}"></view>
            <text wx:if="{{item.changed.role}}" class="hex-role">{{item.changed.role}}</text>
          </view>
        </view>
      </view>
    </view>
    <view class="analysis-panel">
      <view class="analysis-card featured">
        <view class="analysis-title">用神判断</view>
        <view class="analysis-text">{{result.analysis.useGod.text}}</view>
        <view class="strength-strip">
          <text>强弱 {{result.analysis.useGodStrength.label}}</text>
          <text>评分 {{result.analysis.useGodStrength.score}}</text>
        </view>
        <view class="factor-row">
          <text class="factor-tag" wx:for="{{result.analysis.useGodStrength.factors}}" wx:key="*this">{{item}}</text>
        </view>
      </view>
      <view class="analysis-card">
        <view class="analysis-title">用原忌仇</view>
        <view class="god-role-row" wx:for="{{result.analysis.godRoles.roles}}" wx:key="key">
          <view class="god-role-head">
            <text class="analysis-tag">{{item.title}}</text>
            <text>{{item.status}} · {{item.powerLabel}}</text>
          </view>
          <view class="analysis-text">{{item.role}}：{{item.rule}}。{{item.text}}</view>
        </view>
        <view class="decision-row" wx:for="{{result.analysis.godRoles.judgement}}" wx:key="*this">{{item}}</view>
      </view>
      <view class="analysis-card">
        <view class="analysis-title">月建日辰权重</view>
        <view class="analysis-text">{{result.analysis.monthDayPower.text}}</view>
        <view class="power-row" wx:for="{{result.analysis.monthDayPower.focusRows}}" wx:key="position">
          <text class="power-label">{{item.position}}</text>
          <text>{{item.monthEffect}} · {{item.dayEffect}} · {{item.powerLabel}}</text>
        </view>
      </view>
      <view class="analysis-card relation-card">
        <view class="analysis-title">世应用神关系</view>
        <view class="relation-grid">
          <view>
            <text class="relation-label">世爻</text>
            <text>{{result.analysis.shiYing.shi}}</text>
          </view>
          <view>
            <text class="relation-label">应爻</text>
            <text>{{result.analysis.shiYing.ying}}</text>
          </view>
          <view>
            <text class="relation-label">世应</text>
            <text>{{result.analysis.shiYing.shiYingAction}}</text>
          </view>
          <view>
            <text class="relation-label">用神</text>
            <text>世{{result.analysis.shiYing.shiUseAction}} · 应{{result.analysis.shiYing.yingUseAction}}</text>
          </view>
        </view>
        <view class="analysis-text">{{result.analysis.shiYing.text}}</view>
      </view>
      <view class="analysis-card">
        <view class="analysis-title">动爻回头生克</view>
        <block wx:if="{{result.analysis.moving.length}}">
          <view class="analysis-row" wx:for="{{result.analysis.moving}}" wx:key="position">
            <text class="analysis-tag {{item.tone === '凶' ? 'warn' : ''}}">{{item.effect}}</text>
            <text>{{item.text}}</text>
          </view>
        </block>
        <view wx:else class="analysis-text">本卦无动爻，先按静卦看世应、用神、月日旺衰。</view>
      </view>
      <view class="analysis-card" wx:if="{{result.analysis.movingPriority.length}}">
        <view class="analysis-title">动爻优先级</view>
        <view class="priority-row" wx:for="{{result.analysis.movingPriority}}" wx:key="rank">
          <text class="priority-rank">{{item.rank}}</text>
          <text>{{item.position}} · {{item.level}} · {{item.text}}</text>
        </view>
      </view>
      <view class="analysis-card">
        <view class="analysis-title">伏神飞神</view>
        <view class="analysis-text">{{result.analysis.fuFei.status}}：{{result.analysis.fuFei.text}}</view>
      </view>
      <view class="analysis-card">
        <view class="analysis-title">断事要点</view>
        <view class="decision-row" wx:for="{{result.analysis.decision}}" wx:key="*this">{{item}}</view>
      </view>
    </view>
    <view class="result-card final-reading">
      <view class="result-line">{{result.aiText}}</view>
      <view class="result-line">{{result.advice}}</view>
    </view>
  </view>
</view>
