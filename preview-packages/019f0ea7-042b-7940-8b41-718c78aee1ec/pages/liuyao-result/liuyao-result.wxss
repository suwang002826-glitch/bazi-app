@import "../liuyao/liuyao.wxss";

.liuyao-result-page {
  padding: 0 0 calc(32rpx + env(safe-area-inset-bottom));
}

.result-topbar {
  position: sticky;
  top: 0;
  z-index: 5;
  display: grid;
  grid-template-columns: 96rpx 1fr 96rpx;
  align-items: center;
  height: calc(122rpx + env(safe-area-inset-top));
  padding: calc(24rpx + env(safe-area-inset-top)) 18rpx 0;
  border-bottom: 1rpx solid rgba(232, 201, 138, .10);
  background: rgba(6, 16, 22, .96);
  backdrop-filter: blur(18rpx);
}

.result-title {
  color: #dfe8e5;
  font-size: 34rpx;
  font-weight: 800;
  text-align: center;
}

.back-button,
.more-button {
  color: #d8e1de;
  font-size: 46rpx;
  font-weight: 600;
  text-align: center;
}

.more-button {
  font-size: 28rpx;
  letter-spacing: 4rpx;
}

.liuyao-result-shell {
  margin-top: 24rpx;
}

.empty-state {
  margin: 42rpx 24rpx;
  padding: 34rpx;
  border: 1rpx solid rgba(232, 201, 138, .14);
  border-radius: 18rpx;
  background: rgba(10, 24, 29, .82);
  text-align: center;
}

.empty-title {
  margin-bottom: 10rpx;
  color: #f0f4f2;
  font-size: 32rpx;
  font-weight: 900;
}

.empty-copy {
  margin-bottom: 24rpx;
  color: #9fb3b4;
  font-size: 26rpx;
  line-height: 1.6;
}

.empty-state button {
  border-radius: 999rpx;
  background: linear-gradient(135deg, #e9cc8b, #f3dca7);
  color: #1b160e;
  font-size: 27rpx;
  font-weight: 900;
}
