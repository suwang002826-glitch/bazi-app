.qimen-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at 90% 0%, rgba(33, 91, 103, .24), transparent 36%),
    linear-gradient(180deg, #071016 0%, #071823 58%, #08131a 100%);
}

.tool-title-hero {
  position: relative;
  min-height: 226rpx;
  padding: calc(58rpx + env(safe-area-inset-top)) 44rpx 44rpx;
  text-align: center;
}

.tool-title {
  position: relative;
  z-index: 1;
  color: #f2f0e4;
  font-size: 62rpx;
  font-weight: 900;
  letter-spacing: 8rpx;
  line-height: 1.08;
}

.tool-subtitle {
  position: relative;
  z-index: 1;
  margin-top: 20rpx;
  color: rgba(242, 240, 228, .64);
  font-size: 27rpx;
  font-weight: 800;
  letter-spacing: 3rpx;
}

.tool-stamp {
  position: absolute;
  z-index: 1;
  top: calc(72rpx + env(safe-area-inset-top));
  right: 128rpx;
  width: 42rpx;
  min-height: 50rpx;
  padding: 4rpx 0;
  border: 2rpx solid rgba(217, 191, 113, .34);
  color: #d9bf71;
  font-size: 18rpx;
  font-weight: 900;
  line-height: 22rpx;
  text-align: center;
}

.tool-hero {
  overflow: hidden;
  border-color: rgba(153, 198, 190, .24);
  background: #071823;
}

.tool-hero .section-title,
.tool-hero .muted {
  color: #f5fbfc;
}

.tool-hero .section-kicker {
  border-color: rgba(217, 209, 165, .22);
  background: rgba(255, 255, 255, .07);
  color: #e8c98a;
}

.tool-hero-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8rpx;
  margin-top: 22rpx;
}

.tool-hero-grid view {
  min-width: 0;
  padding: 12rpx 6rpx;
  border: 1rpx solid rgba(221, 236, 229, .14);
  border-radius: 12rpx;
  background: rgba(255, 255, 255, .06);
  color: #dceee8;
  font-size: 22rpx;
  font-weight: 800;
  text-align: center;
}

.tool-hero .disclaimer {
  border-color: rgba(215, 206, 154, .28);
  background: rgba(255, 255, 255, .07);
  color: #d9e9e4;
}

.input-panel {
  background: rgba(248, 252, 249, .82);
}

.form-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 0 16rpx;
}

.field.full {
  grid-column: 1 / -1;
}

.ritual-panel {
  margin: 2rpx 0 18rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(94, 72, 28, .18);
  border-radius: 16rpx;
  background: rgba(250, 247, 238, .68);
}

.ritual-title {
  margin-bottom: 10rpx;
  color: #5e481c;
  font-size: 27rpx;
  font-weight: 900;
}

.ritual-row {
  display: grid;
  grid-template-columns: 18rpx 1fr;
  gap: 10rpx;
  margin-top: 8rpx;
  color: #123b39;
  font-size: 24rpx;
  line-height: 1.55;
}

.ritual-dot {
  width: 8rpx;
  height: 8rpx;
  margin-top: 15rpx;
  border-radius: 50%;
  background: #6d5830;
}

.time-btn {
  margin-bottom: 14rpx;
}

.result-shell {
  padding: 24rpx;
}

.result-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.qimen-seal {
  flex: 0 0 auto;
  width: 112rpx;
  min-height: 88rpx;
  padding: 16rpx 10rpx;
  border: 1rpx solid rgba(126, 98, 42, .26);
  border-radius: 16rpx;
  background: rgba(250, 246, 232, .72);
  color: #5e481c;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.35;
  text-align: center;
}

.badge-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin: 8rpx 0 16rpx;
}

.mini-badge {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #1b6b85;
  color: #f5fbfc;
  font-size: 22rpx;
  font-weight: 800;
}

.qimen-meta {
  display: grid;
  grid-template-columns: 1fr;
  gap: 10rpx;
  margin-bottom: 18rpx;
}

.qimen-meta view {
  min-width: 0;
  padding: 14rpx;
  border: 1rpx solid rgba(60, 120, 115, .18);
  border-radius: 14rpx;
  background: rgba(241, 248, 245, .66);
}

.qimen-meta text {
  display: block;
  color: #123b39;
  font-size: 24rpx;
  line-height: 1.45;
}

.qimen-meta text:first-child {
  margin-bottom: 4rpx;
  color: #6d5830;
  font-weight: 900;
}

.qimen-board {
  margin-top: 18rpx;
  padding: 10rpx;
  border: 1rpx solid rgba(7, 64, 62, .22);
  border-radius: 18rpx;
  background: rgba(236, 247, 244, .66);
}

.qimen-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.qimen-row:last-child {
  margin-bottom: 0;
}

.qimen-cell {
  min-height: 164rpx;
  padding: 12rpx 9rpx;
  border: 1rpx solid rgba(60, 120, 115, .18);
  border-radius: 14rpx;
  background: rgba(251, 254, 253, .82);
}

.qimen-cell.good {
  border-color: rgba(13, 117, 109, .28);
  background: rgba(232, 247, 244, .9);
}

.qimen-cell.warn {
  border-color: rgba(138, 43, 34, .22);
  background: rgba(249, 241, 237, .82);
}

.qimen-cell.active {
  border-color: #1b6b85;
  box-shadow: inset 0 0 0 2rpx rgba(11, 111, 104, .18);
}

.cell-head {
  display: flex;
  justify-content: space-between;
  gap: 6rpx;
  color: #6d5830;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 1.3;
}

.cell-main {
  margin-top: 9rpx;
  color: #1f5b70;
  font-size: 28rpx;
  font-weight: 900;
  text-align: center;
}

.cell-line {
  margin-top: 6rpx;
  overflow: hidden;
  color: #254e4c;
  font-size: 20rpx;
  line-height: 1.35;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
}

.cell-tags {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 6rpx;
  margin-top: 8rpx;
}

.cell-tags text {
  padding: 4rpx 8rpx;
  border-radius: 999rpx;
  background: rgba(13, 117, 109, .12);
  color: #1f5b70;
  font-size: 18rpx;
  font-weight: 900;
}

.palace-detail {
  margin-top: 16rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(60, 120, 115, .18);
  border-radius: 16rpx;
  background: rgba(251, 254, 253, .80);
}

.detail-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
}

.detail-tone {
  flex: 0 0 auto;
  max-width: 168rpx;
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(230, 240, 236, .82);
  color: #1f5b70;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 1.3;
  text-align: center;
}

.detail-tone.good {
  background: rgba(191, 224, 218, .84);
}

.detail-tone.warn {
  background: rgba(244, 224, 218, .88);
  color: #8a2b22;
}

.detail-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10rpx;
  margin-top: 14rpx;
}

.detail-grid view {
  min-width: 0;
  padding: 13rpx;
  border-radius: 12rpx;
  background: rgba(241, 248, 245, .70);
}

.detail-grid text {
  display: block;
  overflow: hidden;
  color: #123b39;
  font-size: 23rpx;
  line-height: 1.45;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.detail-grid text:first-child {
  margin-bottom: 4rpx;
  color: #6d5830;
  font-weight: 900;
}

.analysis-card,
.layer-card {
  margin-top: 16rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(60, 120, 115, .18);
  border-radius: 16rpx;
  background: rgba(248, 251, 248, .78);
}

.analysis-card.featured {
  border-color: rgba(27, 111, 104, .32);
  background: linear-gradient(135deg, rgba(232, 247, 244, .88), rgba(248, 251, 248, .76));
}

.analysis-title,
.layer-title {
  margin-bottom: 10rpx;
  color: #061d1f;
  font-size: 28rpx;
  font-weight: 900;
}

.analysis-text,
.analysis-action {
  margin-top: 8rpx;
  color: #123b39;
  font-size: 25rpx;
  line-height: 1.7;
}

.analysis-action {
  padding: 14rpx;
  border-radius: 14rpx;
  background: rgba(250, 247, 238, .78);
  color: #5e481c;
  font-weight: 900;
}

.layer-row {
  display: grid;
  grid-template-columns: 132rpx 1fr;
  gap: 12rpx;
  padding: 11rpx 0;
  border-top: 1rpx solid rgba(60, 120, 115, .12);
  color: #123b39;
  font-size: 24rpx;
  line-height: 1.6;
}

.layer-row:first-of-type {
  border-top: 0;
}

.layer-label {
  color: #6d5830;
  font-weight: 900;
}

.final-reading {
  background: rgba(251, 254, 253, .78);
}

.engine-item {
  position: relative;
  margin-top: 10rpx;
  padding-left: 24rpx;
  color: #214d4a;
  font-size: 24rpx;
  line-height: 1.55;
}

.engine-item::before {
  position: absolute;
  left: 0;
  top: 14rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #1b6b85;
  content: "";
}

.qimen-page {
  color: #dce8e5;
  background:
    radial-gradient(circle at 90% 0%, rgba(33, 91, 103, .24), transparent 36%),
    linear-gradient(180deg, #071016 0%, #071823 58%, #08131a 100%);
}

.qimen-page .section {
  border-color: rgba(129, 176, 184, .18);
  background: rgba(8, 23, 30, .88);
  box-shadow: 0 14rpx 32rpx rgba(0, 0, 0, .18);
}

.qimen-page .section-title,
.qimen-page .analysis-title,
.qimen-page .layer-title {
  color: #f2f6f4;
}

.qimen-page .section-kicker {
  border-color: rgba(232, 201, 138, .24);
  background: rgba(232, 201, 138, .08);
  color: #e8c98a;
}

.qimen-page .muted,
.qimen-page .label,
.qimen-page .analysis-text,
.qimen-page .layer-row,
.qimen-page .result-line {
  color: #b8c9c8;
}

.qimen-page .input-panel {
  padding: 24rpx 22rpx 26rpx;
  border-color: rgba(129, 176, 184, .20);
  background:
    linear-gradient(180deg, rgba(10, 29, 38, .96), rgba(6, 18, 25, .94)),
    #07131a;
}

.qimen-page .input-panel .section-title {
  margin-bottom: 18rpx;
  font-size: 31rpx;
}

.qimen-form-list {
  overflow: hidden;
  margin-top: 8rpx;
  border: 1rpx solid rgba(217, 191, 113, .12);
  border-radius: 16rpx;
  background: rgba(7, 8, 14, .34);
}

.qimen-setting-row {
  display: grid;
  grid-template-columns: 176rpx minmax(0, 1fr);
  align-items: center;
  gap: 18rpx;
  min-height: 96rpx;
  padding: 18rpx 18rpx;
  border-bottom: 1rpx solid rgba(242, 240, 228, .07);
}

.qimen-setting-row:last-child {
  border-bottom: 0;
}

.qimen-question-row {
  align-items: start;
}

.qimen-setting-label {
  color: rgba(242, 240, 228, .78);
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.25;
}

.qimen-question-row textarea {
  min-height: 88rpx;
  height: 88rpx;
  padding: 0;
  border: 0;
  background: transparent;
  color: #f2f0e4;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 44rpx;
  text-align: right;
  box-shadow: none;
}

.qimen-time-value {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
  color: #f2f0e4;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 1.25;
  text-align: right;
}

.time-refresh {
  color: rgba(217, 191, 113, .72);
  font-size: 34rpx;
  line-height: 1;
}

.qimen-option-row {
  align-items: start;
}

.qimen-radio-group {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 14rpx 18rpx;
  min-width: 0;
}

.qimen-radio {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  min-height: 48rpx;
  color: rgba(242, 240, 228, .70);
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.2;
}

.qimen-radio.active {
  color: #f2f0e4;
}

.radio-dot {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 38rpx;
  height: 38rpx;
  border: 3rpx solid rgba(242, 240, 228, .46);
  border-radius: 50%;
  color: #101116;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 38rpx;
}

.qimen-radio.active .radio-dot {
  border-color: rgba(217, 191, 113, .92);
  background: linear-gradient(135deg, #ead78f, #c4a35c);
  box-shadow: 0 0 0 4rpx rgba(217, 191, 113, .08);
}

.qimen-page .field {
  margin-bottom: 18rpx;
}

.qimen-page textarea,
.qimen-page picker {
  border-color: rgba(141, 181, 188, .24);
  background:
    linear-gradient(180deg, rgba(255, 255, 255, .035), rgba(255, 255, 255, .015)),
    rgba(4, 12, 17, .88);
  color: #edf6f3;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, .04);
}

.qimen-page textarea {
  min-height: 176rpx;
  border-radius: 12rpx;
}

.qimen-page textarea::placeholder {
  color: #6f8588;
}

.qimen-page .ritual-panel {
  border-color: rgba(232, 201, 138, .18);
  background: rgba(232, 201, 138, .07);
}

.qimen-page .ritual-title {
  color: #e8c98a;
}

.qimen-page .ritual-row {
  color: #c6d7d4;
}

.qimen-page .ritual-dot {
  background: #e8c98a;
}

.qimen-page button.secondary {
  width: 100%;
  min-height: 78rpx;
  border-radius: 999rpx;
  border-color: rgba(129, 176, 184, .22);
  background: rgba(5, 15, 21, .62);
  color: #a8bcbb;
  font-size: 26rpx;
  line-height: 78rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, .035);
}

.qimen-page button.secondary:active {
  background: rgba(11, 31, 40, .82);
  color: #d2dfdc;
}

.qimen-page button.primary {
  width: 100%;
  min-height: 84rpx;
  margin-top: 14rpx;
  border: 1rpx solid rgba(232, 201, 138, .38);
  border-radius: 999rpx;
  background:
    linear-gradient(135deg, rgba(244, 220, 158, .96), rgba(190, 147, 79, .94)),
    #d7b16a;
  color: #101315;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 84rpx;
  box-shadow:
    0 14rpx 28rpx rgba(0, 0, 0, .22),
    inset 0 1rpx 0 rgba(255, 255, 255, .36);
}

.qimen-page button.primary:active {
  background:
    linear-gradient(135deg, rgba(229, 201, 134, .96), rgba(170, 127, 64, .96)),
    #c49a54;
  transform: translateY(1rpx);
}

.qimen-page .qimen-seal {
  border-color: rgba(232, 201, 138, .32);
  background: rgba(232, 201, 138, .10);
  color: #e8c98a;
}

.qimen-page .mini-badge {
  border: 1rpx solid rgba(232, 201, 138, .18);
  background: rgba(232, 201, 138, .08);
  color: #e8c98a;
}

.qimen-page .qimen-meta view,
.qimen-page .palace-detail,
.qimen-page .analysis-card,
.qimen-page .layer-card,
.qimen-page .final-reading {
  border-color: rgba(129, 176, 184, .16);
  background: rgba(8, 24, 30, .76);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, .04);
}

.qimen-page .qimen-meta text,
.qimen-page .detail-grid text,
.qimen-page .engine-item {
  color: #c6d7d4;
}

.qimen-page .qimen-meta text:first-child,
.qimen-page .detail-grid text:first-child,
.qimen-page .layer-label {
  color: #e8c98a;
}

.qimen-page .qimen-board {
  border-color: rgba(129, 176, 184, .16);
  background: rgba(5, 14, 18, .72);
}

.qimen-page .qimen-cell {
  border-color: rgba(129, 176, 184, .14);
  background: rgba(13, 37, 45, .86);
}

.qimen-page .qimen-cell.good {
  border-color: rgba(83, 170, 152, .24);
  background: rgba(11, 45, 46, .82);
}

.qimen-page .qimen-cell.warn {
  border-color: rgba(202, 96, 80, .24);
  background: rgba(52, 24, 22, .62);
}

.qimen-page .qimen-cell.active {
  border-color: rgba(232, 201, 138, .56);
  box-shadow:
    inset 0 0 0 2rpx rgba(232, 201, 138, .16),
    0 10rpx 22rpx rgba(0, 0, 0, .18);
}

.qimen-page .cell-head {
  color: #8da6a6;
}

.qimen-page .cell-main {
  color: #e8c98a;
}

.qimen-page .cell-line {
  color: #d5e1de;
}

.qimen-page .cell-tags text {
  background: rgba(232, 201, 138, .08);
  color: #e8c98a;
}

.qimen-page .detail-tone {
  border: 1rpx solid rgba(232, 201, 138, .22);
  background: rgba(232, 201, 138, .10);
  color: #e8c98a;
}

.qimen-page .detail-tone.good {
  background: rgba(47, 118, 106, .22);
  color: #bfe4dc;
}

.qimen-page .detail-tone.warn {
  background: rgba(97, 43, 36, .36);
  color: #f0aaa0;
}

.qimen-page .detail-grid view {
  background: rgba(5, 15, 21, .54);
}

.qimen-page .analysis-card.featured {
  border-color: rgba(232, 201, 138, .26);
  background:
    linear-gradient(135deg, rgba(232, 201, 138, .10), rgba(8, 24, 30, .76)),
    rgba(8, 24, 30, .76);
}

.qimen-page .analysis-action {
  background: rgba(232, 201, 138, .08);
  color: #e8c98a;
}

.qimen-page .layer-row {
  border-top-color: rgba(129, 176, 184, .12);
}

.qimen-page .engine-item::before {
  background: #e8c98a;
}

/* Restored tab page palette: align qimen with the current dark Bazi system. */
.qimen-page {
  background:
    radial-gradient(circle at 78% 0%, rgba(58, 62, 116, .22), transparent 34%),
    linear-gradient(180deg, #07080e 0%, #1d1f3a 48%, #090a12 100%);
}

.qimen-page .section,
.qimen-page .input-panel,
.qimen-page .ritual-panel,
.qimen-page .result-shell,
.qimen-page .qimen-board,
.qimen-page .palace-detail,
.qimen-page .analysis-card,
.qimen-page .layer-card,
.qimen-page .final-reading,
.qimen-page .qimen-pro-table {
  border-color: rgba(217, 191, 113, .16);
  background:
    linear-gradient(145deg, rgba(242, 240, 228, .075), rgba(242, 240, 228, .025)),
    rgba(24, 25, 48, .94);
  box-shadow:
    inset 0 1rpx 0 rgba(242, 240, 228, .06),
    0 12rpx 26rpx rgba(0, 0, 0, .22);
}

.qimen-page .section-title,
.qimen-page .ritual-title,
.qimen-page .analysis-title,
.qimen-page .layer-title,
.qimen-page .cell-main,
.qimen-page .pro-value.strong {
  color: #f2f0e4;
}

.qimen-page .section-kicker,
.qimen-page .mini-badge,
.qimen-page .qimen-seal,
.qimen-page .detail-tone,
.qimen-page .cell-tags text,
.qimen-page .analysis-action,
.qimen-page .pro-label {
  border-color: rgba(217, 191, 113, .20);
  background: rgba(217, 191, 113, .10);
  color: #d9bf71;
}

.qimen-page .muted,
.qimen-page .label,
.qimen-page .ritual-row,
.qimen-page .analysis-text,
.qimen-page .layer-row,
.qimen-page .result-line,
.qimen-page .engine-item,
.qimen-page .cell-line,
.qimen-page .pro-value {
  color: rgba(242, 240, 228, .72);
}

.qimen-page .field textarea,
.qimen-page picker,
.qimen-page .qimen-meta view,
.qimen-page .qimen-cell,
.qimen-page .detail-grid view,
.qimen-page .pro-row {
  border-color: rgba(217, 191, 113, .13);
  background: rgba(7, 8, 14, .52);
  color: #f2f0e4;
}

.qimen-page .qimen-cell.good {
  border-color: rgba(95, 169, 140, .28);
  background: rgba(22, 49, 43, .72);
}

.qimen-page .qimen-cell.warn {
  border-color: rgba(194, 99, 86, .26);
  background: rgba(58, 28, 30, .66);
}

.qimen-page .qimen-cell.active {
  border-color: rgba(217, 191, 113, .58);
  box-shadow:
    inset 0 0 0 2rpx rgba(217, 191, 113, .18),
