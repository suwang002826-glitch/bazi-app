.pattern-layer {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 0;
  overflow: hidden;
  pointer-events: none;
}

.pattern-layer::before {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  opacity: .22;
  background:
    linear-gradient(90deg, rgba(143, 178, 188, .032) 1rpx, transparent 1rpx),
    linear-gradient(0deg, rgba(143, 178, 188, .024) 1rpx, transparent 1rpx);
  background-size: 72rpx 72rpx;
  content: "";
}

.pattern-layer::after {
  position: absolute;
  right: -120rpx;
  bottom: -150rpx;
  width: 440rpx;
  height: 440rpx;
  border: 1rpx solid rgba(143, 178, 188, .07);
  border-radius: 50%;
  box-shadow:
    inset 0 0 0 36rpx rgba(255, 255, 255, .035),
    inset 0 0 0 76rpx rgba(143, 178, 188, .032);
  content: "";
}

.pattern-mark {
  position: absolute;
  color: rgba(143, 178, 188, .04);
  font-weight: 800;
  line-height: 1;
}

.pattern-taiji {
  top: 130rpx;
  right: -52rpx;
  font-size: 230rpx;
  transform: rotate(-18deg);
}

.pattern-bagua {
  top: 610rpx;
  left: -54rpx;
  width: 210rpx;
  font-size: 78rpx;
  line-height: 1.05;
  text-align: center;
  transform: rotate(9deg);
}

.pattern-sunmoon {
  right: 32rpx;
  bottom: 310rpx;
  font-size: 66rpx;
  letter-spacing: 12rpx;
  transform: rotate(90deg);
}

.pattern-ruyi {
  left: 32rpx;
  bottom: 152rpx;
  font-size: 54rpx;
  letter-spacing: 8rpx;
}

.star-map {
  position: absolute;
  top: 420rpx;
  right: 62rpx;
  width: 178rpx;
  height: 126rpx;
  opacity: .16;
}

.star-dot {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #8fb2bc;
  box-shadow: 0 0 14rpx rgba(143, 178, 188, .22);
}

.star-dot.s1 { left: 8rpx; top: 54rpx; }
.star-dot.s2 { left: 36rpx; top: 34rpx; }
.star-dot.s3 { left: 70rpx; top: 42rpx; }
