.hero-case {
  overflow: hidden;
  border-color: rgba(153, 198, 190, .24);
  background: #071823;
  color: #f5fbfc;
}

.hero-case .section-title,
.hero-case .muted {
  color: #f5fbfc;
}

.hero-case .section-kicker {
  border-color: rgba(217, 209, 165, .22);
  background: rgba(255, 255, 255, .07);
  color: #e8c98a;
}

.case-card {
  margin-bottom: 18rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(60, 120, 115, .18);
  border-radius: 16rpx;
  background: rgba(248, 251, 248, .78);
  box-shadow: none;
}

.case-card:last-child {
  margin-bottom: 0;
}

.case-filter {
  display: flex;
  gap: 10rpx;
  margin-bottom: 18rpx;
}

.filter-chip {
  flex: 1;
  height: 54rpx;
  border: 1rpx solid rgba(16, 91, 86, .18);
  border-radius: 999rpx;
  background: rgba(251, 254, 253, .76);
  color: #214d4a;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 54rpx;
  text-align: center;
}

.filter-chip.active {
  border-color: #1b6b85;
  background: #1b6b85;
  color: #f5fbfc;
}

.case-head,
.history-save-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.case-main,
.history-info {
  min-width: 0;
  flex: 1;
}

.case-title,
.history-title {
  margin-bottom: 8rpx;
  overflow: hidden;
  color: #061d1f;
  font-size: 30rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.case-tag {
  flex: 0 0 auto;
  max-width: 132rpx;
  min-width: 88rpx;
  height: 46rpx;
  padding: 0 12rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(191, 224, 218, .84);
  color: #1f5b70;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 46rpx;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.case-status {
  display: inline-block;
  margin-top: 14rpx;
  padding: 8rpx 16rpx;
  border: 1rpx solid rgba(126, 98, 42, .16);
  border-radius: 999rpx;
  background: rgba(250, 247, 238, .88);
  color: #6d5830;
  font-size: 23rpx;
  font-weight: 900;
}

.case-summary,
.case-note {
  display: -webkit-box;
  margin-top: 14rpx;
  overflow: hidden;
  color: #123b39;
  font-size: 25rpx;
  line-height: 1.7;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
}

.case-note {
  color: #5b6f6d;
  -webkit-line-clamp: 2;
}

.case-version {
  margin-top: 10rpx;
  color: #6f827e;
  font-size: 21rpx;
}

.case-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.small-btn {
  width: 184rpx;
  height: 58rpx;
  min-height: 58rpx;
  margin: 0;
  font-size: 24rpx;
  line-height: 58rpx;
}

.ghost-btn {
  flex: 1;
}

.danger-btn {
  width: 132rpx;
  border-color: rgba(138, 43, 34, .22);
  color: #8a2b22;
}

.feedback-panel {
  margin-top: 16rpx;
  padding: 16rpx;
  border: 1rpx solid rgba(60, 120, 115, .16);
  border-radius: 14rpx;
  background: rgba(241, 248, 245, .68);
}

.feedback-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.feedback-title {
  color: #1f5b70;
  font-size: 26rpx;
  font-weight: 900;
}

.verify-btn {
  flex: 0 0 auto;
  width: 190rpx;
  height: 54rpx;
  min-height: 54rpx;
  margin: 0;
  font-size: 22rpx;
  line-height: 54rpx;
}

.feedback-field {
  margin-top: 12rpx;
}

.feedback-field text {
  display: block;
  margin-bottom: 8rpx;
  color: #6d5830;
  font-size: 22rpx;
  font-weight: 900;
}

.feedback-field input,
.feedback-field textarea {
  min-height: 70rpx;
  border-radius: 12rpx;
  background: rgba(253, 255, 252, .88);
  font-size: 24rpx;
}

.feedback-field textarea {
  min-height: 98rpx;
}

.history-save-row {
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(60, 120, 115, .16);
}

.history-save-row:last-child {
  border-bottom: 0;
}

.save-btn {
  flex: 0 0 auto;
  width: 132rpx;
  height: 56rpx;
  min-height: 56rpx;
  margin: 0;
  font-size: 24rpx;
  line-height: 56rpx;
}

.empty-text {
  padding: 22rpx;
  border-radius: 14rpx;
  background: rgba(230, 240, 236, .62);
  color: #365b58;
  font-size: 25rpx;
  line-height: 1.65;
}
