.cases-page {
  min-height: 100vh;
  padding: calc(30rpx + env(safe-area-inset-top)) 22rpx calc(52rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #07080e 0%, #101127 52%, #07080e 100%);
  color: #f2f0e4;
}

.case-library-head {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
}

.library-title {
  min-width: 260rpx;
  min-height: 76rpx;
  padding: 0 44rpx;
  border: 1rpx solid rgba(217, 191, 113, .12);
  border-radius: 999rpx;
  background: rgba(242, 240, 228, .92);
  color: #222559;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 76rpx;
  text-align: center;
  box-shadow: 0 10rpx 20rpx rgba(0, 0, 0, .22);
}

.case-search {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-height: 82rpx;
  padding: 0 20rpx;
  border: 1rpx solid rgba(217, 191, 113, .10);
  border-radius: 16rpx;
  background: rgba(242, 240, 228, .055);
}

.search-icon {
  color: rgba(242, 240, 228, .38);
  font-size: 38rpx;
  line-height: 1;
}

.case-search input {
  flex: 1;
  height: 76rpx;
  min-width: 0;
  padding: 0;
  border: 0;
  background: transparent;
  color: #f2f0e4;
  font-size: 28rpx;
  box-shadow: none;
}

.filter-entry {
  flex: 0 0 auto;
  min-height: 62rpx;
  padding-left: 20rpx;
  border-left: 1rpx solid rgba(242, 240, 228, .10);
  color: #d9bf71;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 62rpx;
}

.case-category-row {
  display: flex;
  gap: 42rpx;
  margin: 28rpx 0 18rpx;
  overflow-x: auto;
  color: rgba(242, 240, 228, .42);
  font-size: 31rpx;
  font-weight: 900;
  white-space: nowrap;
}

.case-category-row text {
  position: relative;
  min-height: 56rpx;
  padding-bottom: 14rpx;
  line-height: 42rpx;
}

.case-category-row .active {
  color: #d9bf71;
}

.case-category-row .active::after {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 3rpx;
  border-radius: 999rpx;
  background: #d9bf71;
  content: "";
}

.case-list-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 166rpx 98rpx;
  gap: 14rpx;
  align-items: center;
  min-height: 174rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(242, 240, 228, .08);
}

.tap-active {
  opacity: .72;
  transform: scale(.995);
}

.case-left {
  min-width: 0;
}

.case-name-line {
  display: flex;
  align-items: baseline;
  gap: 18rpx;
  min-width: 0;
}

.case-display-name {
  max-width: 270rpx;
  overflow: hidden;
  color: #f2f0e4;
  font-size: 35rpx;
  font-weight: 900;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.case-gender {
  color: rgba(242, 240, 228, .52);
  font-size: 28rpx;
  font-weight: 900;
}

.case-date {
  margin-top: 18rpx;
  overflow: hidden;
  color: rgba(242, 240, 228, .56);
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.case-archive-time {
  margin-top: 10rpx;
  color: rgba(242, 240, 228, .34);
  font-size: 21rpx;
  font-weight: 800;
}

.case-pillars {
  min-width: 0;
}

.pillar-char-row {
  display: flex;
  justify-content: flex-end;
  gap: 6rpx;
  min-height: 42rpx;
}

.pillar-char {
  min-width: 36rpx;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.12;
  text-align: center;
}

.pillar-char.wood {
  color: #58c779;
}

.pillar-char.fire {
  color: #e45757;
}

.pillar-char.earth {
  color: #b68a47;
}

.pillar-char.metal {
  color: #d9bf71;
}

.pillar-char.water {
  color: #4aa7e8;
}

.case-actions {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: flex-end;
  gap: 8rpx;
}

.case-seal {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 68rpx;
  height: 68rpx;
  border: 2rpx solid rgba(217, 191, 113, .55);
  border-radius: 50%;
  background:
    radial-gradient(circle, rgba(217, 191, 113, .18), rgba(7, 8, 14, .72) 62%),
    #07080e;
  color: #d9bf71;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1;
}

.case-index-letter {
  position: absolute;
  right: -10rpx;
  top: -16rpx;
  min-width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #d9bf71;
  color: #222559;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 36rpx;
  text-align: center;
}

.case-action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  min-height: 42rpx;
  border: 1rpx solid rgba(217, 191, 113, .16);
  border-radius: 999rpx;
  background: rgba(242, 240, 228, .055);
  color: rgba(242, 240, 228, .74);
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1.2;
}

.view-btn {
  color: #d9bf71;
}

.delete-btn {
  border-color: rgba(203, 91, 79, .22);
  color: #e9a096;
}

.archive-empty {
  margin-top: 34rpx;
  padding: 46rpx 28rpx;
  border: 1rpx solid rgba(217, 191, 113, .12);
  border-radius: 20rpx;
  background:
    radial-gradient(circle at 50% 0%, rgba(217, 191, 113, .12), transparent 42%),
    linear-gradient(145deg, rgba(242, 240, 228, .075), rgba(242, 240, 228, .025)),
    rgba(18, 21, 50, .86);
  text-align: center;
}

.empty-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 76rpx;
  height: 76rpx;
  margin: 0 auto 18rpx;
  border: 1rpx solid rgba(217, 191, 113, .30);
  border-radius: 50%;
  color: #d9bf71;
  font-size: 34rpx;
  font-weight: 900;
}

.empty-title {
  color: #f2f0e4;
  font-size: 32rpx;
  font-weight: 900;
}

.empty-copy {
  margin: 12rpx auto 24rpx;
  color: rgba(242, 240, 228, .58);
  font-size: 25rpx;
  line-height: 1.65;
}

.empty-action {
  width: 246rpx;
  margin: 0 auto;
}
