<view class="page cases-page">
  <view class="case-library-head">
    <view class="library-title">复盘记录</view>
  </view>

  <view class="case-search">
    <text class="search-icon">⌕</text>
    <input placeholder="搜索姓名、问题、卦名或时间" value="{{query}}" bindinput="onSearchInput" />
    <view class="filter-entry" bindtap="openFilterSheet">筛选</view>
  </view>

  <view class="case-category-row">
    <text
      class="{{activeCategory === item ? 'active' : ''}}"
      wx:for="{{categories}}"
      wx:key="*this"
      bindtap="onCategoryTap"
      data-category="{{item}}"
    >{{item}}</text>
  </view>

  <block wx:if="{{cases.length}}">
    <view
      class="case-swipe-row {{openedDeleteId === item.id ? 'show-delete' : ''}}"
      wx:for="{{cases}}"
      wx:key="id"
    >
      <view class="case-delete-panel" catchtap="deleteCase" data-id="{{item.id}}">删除</view>
      <view
        class="case-list-row"
        bindtap="openCase"
        bindtouchstart="onCaseTouchStart"
        bindtouchmove="onCaseTouchMove"
        bindtouchend="onCaseTouchEnd"
        data-id="{{item.id}}"
        hover-class="tap-active"
      >
        <view class="case-left">
          <view class="case-name-line">
            <text class="case-display-name">{{item.displayName}}</text>
            <text class="case-gender">{{item.typeLabel}}</text>
          </view>
          <view class="case-date">{{item.detailLine}}</view>
          <view class="case-archive-time">{{item.subLine}}</view>
        </view>

        <view wx:if="{{item.typeKey === 'bazi'}}" class="case-pillars">
          <view class="pillar-char-row" wx:for="{{item.pillarRows}}" wx:for-item="row" wx:key="*this">
            <text
              class="pillar-char {{char.className}}"
              wx:for="{{row}}"
              wx:for-item="char"
              wx:key="index"
            >{{char.char}}</text>
          </view>
        </view>
        <view wx:else class="liuyao-case-summary">
          <view class="liuyao-case-title">{{item.liuyaoSummary}}</view>
          <view class="liuyao-case-tags">
            <text wx:for="{{item.liuyaoTags}}" wx:key="*this">{{item}}</text>
          </view>
        </view>

        <view wx:if="{{item.typeKey === 'bazi'}}" class="zodiac-seal {{item.zodiacSeal.className}}">
          <image class="zodiac-image" src="{{item.zodiacSeal.icon}}" mode="aspectFit" />
        </view>
        <view wx:else class="case-symbol liuyao-symbol">卦</view>
      </view>
    </view>
  </block>

  <view wx:else class="archive-empty">
    <view class="empty-mark">录</view>
    <view class="empty-title">暂无复盘记录</view>
    <view class="empty-copy">{{emptyText}}</view>
    <button class="primary empty-action" bindtap="goBazi">去排盘</button>
  </view>
</view>
