<view class="page cases-page">
  <view class="case-library-head">
    <view class="library-title">命例档案</view>
  </view>

  <view class="case-search">
    <text class="search-icon">⌕</text>
    <input placeholder="请输入搜索的内容" value="{{query}}" bindinput="onSearchInput" />
    <view class="filter-entry" bindtap="openFilterSheet">筛选</view>
  </view>

  <view class="case-category-row">
    <text
      class="{{activeCategory === item ? 'active' : ''}}"
      wx:for="{{categories}}"
      wx:key="*this"
      bindtap="onCategoryTap"
      data-category="{{item}}"
    >{{item}}</text>
  </view>

  <block wx:if="{{cases.length}}">
    <view
      class="case-list-row"
      wx:for="{{cases}}"
      wx:key="id"
      hover-class="tap-active"
    >
      <view class="case-left" bindtap="openCase" data-id="{{item.id}}">
        <view class="case-name-line">
          <text class="case-display-name">{{item.displayName}}</text>
          <text class="case-gender">{{item.gender}}</text>
        </view>
        <view class="case-date">阳历{{item.solarDate}}</view>
        <view class="case-archive-time">{{item.archivedAt}}</view>
      </view>
      <view class="case-pillars" bindtap="openCase" data-id="{{item.id}}">
        <view class="pillar-char-row" wx:for="{{item.pillarRows}}" wx:for-item="row" wx:key="*this">
          <text
            class="pillar-char {{char.className}}"
            wx:for="{{row}}"
            wx:for-item="char"
            wx:key="char"
          >{{char.char}}</text>
        </view>
      </view>
      <view class="case-actions">
        <view class="case-seal">{{item.sealText}}</view>
        <text wx:if="{{item.indexLetter}}" class="case-index-letter">{{item.indexLetter}}</text>
        <view class="case-action-btn view-btn" catchtap="openCase" data-id="{{item.id}}">看</view>
        <view class="case-action-btn delete-btn" catchtap="deleteCase" data-id="{{item.id}}">删</view>
      </view>
    </view>
  </block>

  <view wx:else class="archive-empty">
    <view class="empty-mark">命</view>
    <view class="empty-title">暂无命例</view>
    <view class="empty-copy">{{emptyText}}</view>
    <button class="primary empty-action" bindtap="goBazi">去排盘</button>
  </view>
</view>
