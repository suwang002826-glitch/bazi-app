.home-page {
  min-height: 100vh;
  padding: 0 0 calc(44rpx + env(safe-area-inset-bottom));
  background:
    linear-gradient(180deg, #050b10 0%, #071823 48%, #091d2a 100%);
}

.home-shell {
  position: relative;
  z-index: 1;
  padding: 36rpx 24rpx 0;
}

.brand-row {
  display: grid;
  grid-template-columns: 76rpx 1fr 86rpx;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 28rpx;
}

.brand-logo {
  width: 72rpx;
  height: 72rpx;
  border: 1rpx solid rgba(232, 201, 138, .42);
  border-radius: 50%;
  background: #071823;
}

.brand-copy {
  min-width: 0;
}

.brand-title {
  color: #f2dfb5;
  font-family: "Kaiti SC", "STKaiti", "KaiTi", "Songti SC", "SimSun", serif;
  font-size: 44rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
  line-height: 1.12;
}

.brand-subtitle {
  margin-top: 6rpx;
  color: rgba(216, 232, 238, .68);
  font-size: 22rpx;
}

.version-badge {
  height: 46rpx;
  border: 1rpx solid rgba(232, 201, 138, .34);
  border-radius: 999rpx;
  color: #e8c98a;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 44rpx;
  text-align: center;
}

.product-list {
  display: grid;
  grid-template-columns: 1fr;
  gap: 22rpx;
}

.product-card {
  position: relative;
  min-height: 318rpx;
  overflow: hidden;
  border: 1rpx solid rgba(119, 158, 173, .24);
  border-radius: 14rpx;
  background: #071823;
  box-shadow: 0 16rpx 34rpx rgba(0, 0, 0, .24);
}

.product-card:active {
  transform: translateY(1rpx);
}

.product-bg,
.product-shade {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.product-bg {
  opacity: .88;
}

.product-shade {
  background:
    linear-gradient(90deg, rgba(5, 11, 16, .94) 0%, rgba(5, 11, 16, .78) 38%, rgba(5, 11, 16, .25) 72%, rgba(5, 11, 16, .12) 100%),
    linear-gradient(180deg, rgba(5, 11, 16, .12), rgba(5, 11, 16, .72));
}

.product-content {
  position: relative;
  z-index: 1;
  width: 68%;
  padding: 34rpx 30rpx 92rpx;
}

.product-symbol {
  width: 58rpx;
  height: 58rpx;
  margin-bottom: 18rpx;
  border: 1rpx solid rgba(232, 201, 138, .48);
  border-radius: 50%;
  color: #e8c98a;
  font-family: "Kaiti SC", "STKaiti", "KaiTi", serif;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 56rpx;
  text-align: center;
}

.product-title {
  color: #fff3d3;
  font-family: "Kaiti SC", "STKaiti", "KaiTi", "Songti SC", "SimSun", serif;
  font-size: 44rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
  line-height: 1.16;
}

.product-desc {
  margin-top: 12rpx;
  color: rgba(230, 242, 245, .82);
  font-size: 26rpx;
  line-height: 1.48;
}

.product-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 20rpx;
}

.product-tags text {
  padding: 6rpx 12rpx;
  border: 1rpx solid rgba(232, 201, 138, .20);
  border-radius: 999rpx;
  background: rgba(232, 201, 138, .10);
  color: #efd39b;
  font-size: 21rpx;
  font-weight: 800;
}

.product-action {
  position: absolute;
  left: 30rpx;
  bottom: 26rpx;
  z-index: 1;
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  height: 58rpx;
  padding: 0 20rpx;
  border: 1rpx solid rgba(232, 201, 138, .30);
  border-radius: 999rpx;
  background: rgba(11, 38, 50, .76);
  color: #f2dfb5;
  font-size: 24rpx;
  font-weight: 900;
}

.arrow {
  width: 30rpx;
  height: 30rpx;
  border: 1rpx solid rgba(242, 223, 181, .58);
  border-radius: 50%;
  line-height: 26rpx;
  text-align: center;
}
