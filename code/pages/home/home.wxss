.home-page {
  min-height: 100vh;
  padding: 0 0 calc(44rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #07080e 0%, #101127 50%, #07080e 100%);
  color: #f2f0e4;
}

.home-shell {
  position: relative;
  z-index: 1;
  padding: 30rpx 24rpx 0;
}

.brand-row {
  display: grid;
  grid-template-columns: 84rpx 1fr 82rpx;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(217, 191, 113, .16);
  border-radius: 16rpx;
  background:
    linear-gradient(145deg, rgba(242, 240, 228, .08), rgba(242, 240, 228, .025)),
    rgba(7, 8, 14, .48);
  box-shadow:
    inset 0 1rpx 0 rgba(242, 240, 228, .08),
    0 8rpx 16rpx rgba(0, 0, 0, .20);
}

.brand-logo-shell {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 78rpx;
  height: 78rpx;
  border: 1rpx solid rgba(217, 191, 113, .30);
  border-radius: 50%;
  background: radial-gradient(circle at 50% 42%, rgba(217, 191, 113, .18), rgba(18, 21, 50, .70));
  box-shadow:
    inset 0 0 0 4rpx rgba(7, 8, 14, .58),
    0 4rpx 10rpx rgba(0, 0, 0, .22);
}

.brand-logo {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
}

.brand-copy {
  min-width: 0;
}

.brand-title {
  color: #f2f0e4;
  font-family: "KaiTi", "STKaiti", "Kaiti SC", "楷体", "SimKai", serif;
  font-size: 44rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
  line-height: 1.12;
}

.brand-subtitle {
  margin-top: 6rpx;
  color: rgba(242, 240, 228, .58);
  font-size: 22rpx;
}

.version-badge {
  height: 46rpx;
  border: 1rpx solid rgba(217, 191, 113, .26);
  border-radius: 999rpx;
  background: rgba(217, 191, 113, .10);
  color: #d9bf71;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 44rpx;
  text-align: center;
}

.calendar-card {
  position: relative;
  overflow: hidden;
  padding: 40rpx 34rpx 32rpx;
  border: 1rpx solid rgba(217, 191, 113, .18);
  border-radius: 16rpx;
  background:
    linear-gradient(145deg, rgba(242, 240, 228, .08), rgba(242, 240, 228, .025)),
    rgba(18, 21, 50, .92);
  box-shadow:
    inset 0 1rpx 0 rgba(242, 240, 228, .10),
    0 8rpx 18rpx rgba(0, 0, 0, .24);
}

.calendar-date {
  color: #f2f0e4;
  font-family: "KaiTi", "STKaiti", "Kaiti SC", "楷体", "SimKai", serif;
  font-size: 58rpx;
  font-weight: 900;
  line-height: 1.08;
}

.calendar-sub {
  margin-top: 10rpx;
  color: rgba(242, 240, 228, .62);
  font-size: 27rpx;
  font-weight: 700;
}

.ganzhi-panel {
  margin-top: 34rpx;
  padding: 22rpx;
  border: 1rpx solid rgba(242, 240, 228, .08);
  border-radius: 12rpx;
  background: rgba(7, 8, 14, .38);
}

.ganzhi-title,
.daily-label,
.note-label {
  color: rgba(242, 240, 228, .50);
  font-size: 23rpx;
  font-weight: 800;
}

.ganzhi-value {
  margin-top: 10rpx;
  color: #d9bf71;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.35;
}

.daily-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 18rpx;
}

.daily-grid view {
  padding: 18rpx 12rpx;
  border: 1rpx solid rgba(242, 240, 228, .07);
  border-radius: 10rpx;
  background: rgba(242, 240, 228, .06);
  text-align: center;
}

.daily-value {
  display: block;
  margin-top: 8rpx;
  color: #f2f0e4;
  font-size: 26rpx;
  font-weight: 900;
}

.almanac-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 10rpx;
  margin-top: 20rpx;
  color: rgba(242, 240, 228, .82);
  font-size: 24rpx;
  font-weight: 800;
}

.almanac-row text:not(.almanac-label) {
  padding: 7rpx 14rpx;
  border: 1rpx solid rgba(242, 240, 228, .07);
  border-radius: 999rpx;
  background: rgba(70, 59, 140, .18);
}

.almanac-row.avoid text:not(.almanac-label) {
  background: rgba(159, 136, 191, .12);
}

.almanac-label {
  color: #d9bf71;
  font-weight: 900;
}

.note-list {
  display: grid;
  gap: 14rpx;
  margin-top: 22rpx;
}

.note-item {
  padding: 22rpx 24rpx;
  border: 1rpx solid rgba(217, 191, 113, .12);
  border-radius: 12rpx;
  background: rgba(242, 240, 228, .06);
}

.note-value {
  margin-top: 8rpx;
  color: #f2f0e4;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.48;
}

/* Premium header/material pass. */
.brand-title,
.calendar-date {
  font-family: "KaiTi", "STKaiti", "Kaiti SC", "SimKai", serif;
}

.brand-title {
  font-size: 42rpx;
  letter-spacing: 2rpx;
}

.brand-subtitle {
  margin-top: 8rpx;
  color: rgba(217, 191, 113, .70);
  letter-spacing: 1rpx;
}

.version-badge {
  height: 44rpx;
  border-color: rgba(217, 191, 113, .30);
  background: rgba(217, 191, 113, .12);
  line-height: 42rpx;
}

.calendar-card {
  padding: 38rpx 32rpx 30rpx;
  border-color: rgba(217, 191, 113, .20);
  background:
    linear-gradient(145deg, rgba(242, 240, 228, .095), rgba(242, 240, 228, .026)),
    rgba(18, 21, 50, .92);
}

.ganzhi-panel {
  border-color: rgba(217, 191, 113, .12);
  background: rgba(7, 8, 14, .46);
}

.daily-grid view {
  border-color: rgba(217, 191, 113, .10);
  background: rgba(7, 8, 14, .28);
}

.note-item {
  border-color: rgba(217, 191, 113, .14);
  background:
    linear-gradient(145deg, rgba(242, 240, 228, .07), rgba(242, 240, 228, .025)),
    rgba(18, 21, 50, .66);
}
