.home-page {
  min-height: 100vh;
  padding: 0 0 calc(44rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 16% 0%, rgba(159, 136, 191, .30), transparent 30%),
    linear-gradient(180deg, #f2f0e4 0%, #ece8dc 62%, #ddd4c0 100%);
  color: #222559;
}

.home-shell {
  position: relative;
  z-index: 1;
  padding: 36rpx 24rpx 0;
}

.brand-row {
  display: grid;
  grid-template-columns: 76rpx 1fr 86rpx;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 28rpx;
}

.brand-logo {
  width: 72rpx;
  height: 72rpx;
  border: 1rpx solid rgba(70, 59, 140, .22);
  border-radius: 50%;
  background: #222559;
}

.brand-copy {
  min-width: 0;
}

.brand-title {
  color: #222559;
  font-family: "Songti SC", "SimSun", "Kaiti SC", serif;
  font-size: 44rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
  line-height: 1.12;
}

.brand-subtitle {
  margin-top: 6rpx;
  color: rgba(34, 37, 89, .62);
  font-size: 22rpx;
}

.version-badge {
  height: 46rpx;
  border: 1rpx solid rgba(70, 59, 140, .18);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, .30);
  color: #463b8c;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 44rpx;
  text-align: center;
}

.calendar-card {
  position: relative;
  overflow: hidden;
  padding: 34rpx 32rpx 30rpx;
  border: 1rpx solid rgba(70, 59, 140, .18);
  border-radius: 18rpx;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, .84), rgba(242, 240, 228, .74)),
    radial-gradient(circle at 86% 10%, rgba(217, 191, 113, .30), transparent 28%);
  box-shadow: 0 18rpx 40rpx rgba(34, 37, 89, .10);
}

.calendar-card::after {
  position: absolute;
  right: -82rpx;
  bottom: -92rpx;
  width: 300rpx;
  height: 300rpx;
  border: 2rpx solid rgba(70, 59, 140, .08);
  border-radius: 50%;
  content: "";
}

.calendar-mark {
  display: inline-flex;
  align-items: center;
  height: 46rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #222559;
  color: #f2f0e4;
  font-size: 22rpx;
  font-weight: 900;
}

.calendar-date {
  margin-top: 30rpx;
  color: #222559;
  font-family: "Songti SC", "SimSun", "Kaiti SC", serif;
  font-size: 58rpx;
  font-weight: 900;
  line-height: 1.08;
}

.calendar-sub {
  margin-top: 10rpx;
  color: rgba(34, 37, 89, .68);
  font-size: 27rpx;
  font-weight: 700;
}

.ganzhi-panel {
  margin-top: 34rpx;
  padding: 22rpx;
  border-radius: 14rpx;
  background: rgba(34, 37, 89, .06);
}

.ganzhi-title,
.daily-label,
.note-label {
  color: rgba(34, 37, 89, .56);
  font-size: 23rpx;
  font-weight: 800;
}

.ganzhi-value {
  margin-top: 10rpx;
  color: #463b8c;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.35;
}

.daily-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 18rpx;
}

.daily-grid view {
  padding: 18rpx 12rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, .44);
  text-align: center;
}

.daily-value {
  display: block;
  margin-top: 8rpx;
  color: #222559;
  font-size: 26rpx;
  font-weight: 900;
}

.almanac-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 10rpx;
  margin-top: 20rpx;
  color: #222559;
  font-size: 24rpx;
  font-weight: 800;
}

.almanac-row text:not(.almanac-label) {
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(70, 59, 140, .10);
}

.almanac-row.avoid text:not(.almanac-label) {
  background: rgba(159, 136, 191, .16);
}

.almanac-label {
  color: #d9bf71;
  font-weight: 900;
}

.note-list {
  display: grid;
  gap: 14rpx;
  margin-top: 22rpx;
}

.note-item {
  padding: 22rpx 24rpx;
  border: 1rpx solid rgba(70, 59, 140, .12);
  border-radius: 14rpx;
  background: rgba(255, 255, 255, .42);
}

.note-value {
  margin-top: 8rpx;
  color: #222559;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.48;
}

.bazi-entry {
  display: grid;
  grid-template-columns: 1fr 58rpx;
  align-items: center;
  gap: 18rpx;
  margin-top: 24rpx;
  padding: 26rpx 28rpx;
  border-radius: 999rpx;
  background: #222559;
  box-shadow: 0 18rpx 34rpx rgba(34, 37, 89, .18);
}

.entry-title {
  color: #f2f0e4;
  font-size: 30rpx;
  font-weight: 900;
}

.entry-copy {
  margin-top: 6rpx;
  color: rgba(242, 240, 228, .72);
  font-size: 23rpx;
}

.entry-arrow {
  color: #d9bf71;
  font-size: 58rpx;
  line-height: 1;
  text-align: center;
}
