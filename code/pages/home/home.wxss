.home-page {
  min-height: 100vh;
  padding: 0 0 calc(44rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #07080e 0%, #101127 50%, #07080e 100%);
  color: #f2f0e4;
}

.home-shell {
  position: relative;
  z-index: 1;
  padding: 36rpx 24rpx 0;
}

.brand-row {
  display: grid;
  grid-template-columns: 76rpx 1fr 86rpx;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 28rpx;
}

.brand-logo {
  width: 72rpx;
  height: 72rpx;
  border: 1rpx solid rgba(217, 191, 113, .30);
  border-radius: 50%;
  background: #222559;
}

.brand-copy {
  min-width: 0;
}

.brand-title {
  color: #f2f0e4;
  font-family: "Songti SC", "STSong", "SimSun", serif;
  font-size: 44rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
  line-height: 1.12;
}

.brand-subtitle {
  margin-top: 6rpx;
  color: rgba(242, 240, 228, .58);
  font-size: 22rpx;
}

.version-badge {
  height: 46rpx;
  border: 1rpx solid rgba(217, 191, 113, .26);
  border-radius: 999rpx;
  background: rgba(217, 191, 113, .10);
  color: #d9bf71;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 44rpx;
  text-align: center;
}

.calendar-card {
  position: relative;
  overflow: hidden;
  padding: 40rpx 34rpx 32rpx;
  border: 1rpx solid rgba(217, 191, 113, .18);
  border-radius: 20rpx;
  background:
    linear-gradient(145deg, rgba(242, 240, 228, .08), rgba(242, 240, 228, .025)),
    rgba(18, 21, 50, .92);
  box-shadow:
    inset 0 1rpx 0 rgba(242, 240, 228, .10),
    0 24rpx 54rpx rgba(0, 0, 0, .30);
}

.calendar-date {
  color: #f2f0e4;
  font-family: "Songti SC", "STSong", "SimSun", serif;
  font-size: 58rpx;
  font-weight: 900;
  line-height: 1.08;
}

.calendar-sub {
  margin-top: 10rpx;
  color: rgba(242, 240, 228, .62);
  font-size: 27rpx;
  font-weight: 700;
}

.ganzhi-panel {
  margin-top: 34rpx;
  padding: 22rpx;
  border: 1rpx solid rgba(242, 240, 228, .08);
  border-radius: 14rpx;
  background: rgba(7, 8, 14, .38);
}

.ganzhi-title,
.daily-label,
.note-label {
  color: rgba(242, 240, 228, .50);
  font-size: 23rpx;
  font-weight: 800;
}

.ganzhi-value {
  margin-top: 10rpx;
  color: #d9bf71;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.35;
}

.daily-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 18rpx;
}

.daily-grid view {
  padding: 18rpx 12rpx;
  border: 1rpx solid rgba(242, 240, 228, .07);
  border-radius: 12rpx;
  background: rgba(242, 240, 228, .06);
  text-align: center;
}

.daily-value {
  display: block;
  margin-top: 8rpx;
  color: #f2f0e4;
  font-size: 26rpx;
  font-weight: 900;
}

.almanac-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 10rpx;
  margin-top: 20rpx;
  color: rgba(242, 240, 228, .82);
  font-size: 24rpx;
  font-weight: 800;
}

.almanac-row text:not(.almanac-label) {
  padding: 7rpx 14rpx;
  border: 1rpx solid rgba(242, 240, 228, .07);
  border-radius: 999rpx;
  background: rgba(70, 59, 140, .18);
}

.almanac-row.avoid text:not(.almanac-label) {
  background: rgba(159, 136, 191, .12);
}

.almanac-label {
  color: #d9bf71;
  font-weight: 900;
}

.note-list {
  display: grid;
  gap: 14rpx;
  margin-top: 22rpx;
}

.note-item {
  padding: 22rpx 24rpx;
  border: 1rpx solid rgba(217, 191, 113, .12);
  border-radius: 14rpx;
  background: rgba(242, 240, 228, .06);
}

.note-value {
  margin-top: 8rpx;
  color: #f2f0e4;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.48;
}
