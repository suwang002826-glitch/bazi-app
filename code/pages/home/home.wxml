<view class="page home-page">
  <view class="home-shell">
    <view class="brand-row">
      <view class="brand-logo-shell">
        <image class="brand-logo" src="/assets/home/logo.png" mode="aspectFit" />
      </view>
      <view class="brand-copy">
        <view class="brand-title">玄门命理</view>
        <view class="brand-subtitle">万年历 · 道历 · 八字排盘</view>
      </view>
      <view class="version-badge">内测</view>
    </view>

    <view class="calendar-card">
      <view class="calendar-date">{{today.solar}}</view>
      <view class="calendar-sub">{{today.weekday}} · {{today.lunar}}</view>

      <view class="ganzhi-panel">
        <view class="ganzhi-title">今日干支</view>
        <view class="ganzhi-value">{{today.ganzhi}}</view>
      </view>

      <view class="daily-grid">
        <view>
          <text class="daily-label">道历</text>
          <text class="daily-value">{{today.daoDate}}</text>
        </view>
        <view>
          <text class="daily-label">值日</text>
          <text class="daily-value">{{today.duty}}</text>
        </view>
        <view>
          <text class="daily-label">冲煞</text>
          <text class="daily-value">{{today.clash}}</text>
        </view>
      </view>

      <view class="almanac-row">
        <text class="almanac-label">宜</text>
        <text wx:for="{{today.suit}}" wx:key="*this">{{item}}</text>
      </view>
      <view class="almanac-row avoid">
        <text class="almanac-label">忌</text>
        <text wx:for="{{today.avoid}}" wx:key="*this">{{item}}</text>
      </view>
    </view>

    <view class="note-list">
      <view class="note-item" wx:for="{{calendarNotes}}" wx:key="label">
        <view class="note-label">{{item.label}}</view>
        <view class="note-value">{{item.value}}</view>
      </view>
    </view>

  </view>
</view>
