<view class="page bazi-result-page">
  <view class="result-topbar">
    <view class="back-button" bindtap="goBack">返回</view>
    <view class="result-title">八字排盘结果</view>
    <view class="more-button">
      <button class="share-button" open-type="share" hover-class="none">分享</button>
    </view>
  </view>

  <view wx:if="{{!result}}" class="empty-state">
    <view class="empty-title">无可显示排盘结果</view>
    <view class="empty-copy">请先返回输入页重新排盘。</view>
    <button bindtap="goBack">返回输入页</button>
  </view>

  <view wx:else class="result-shell">
    <view class="bazi-profile">
      <view class="profile-seal">{{result.dayMaster.stem}}</view>
      <view class="profile-main">
        <view class="profile-name">{{result.destinyLabel || '乾造'}} {{result.displayName}}</view>
        <view class="profile-time">性别：{{result.personProfile && result.personProfile.gender === '女' ? '女命' : '男命'}}</view>
        <view class="profile-time">生日：{{result.calendarInfo && result.calendarInfo.inputText ? result.calendarInfo.inputText : result.solarTime}}</view>
        <view class="profile-time" wx:if="{{result.calendarInfo && result.calendarInfo.outputText}}">公历：{{result.calendarInfo.outputText}}</view>
        <view class="profile-time" wx:if="{{result.calendarInfo && result.calendarInfo.mode}}">历法：{{result.calendarInfo.mode}}</view>
        <view class="profile-time">真太阳时：{{result.adjustedSolarTime}}</view>
        <view class="profile-place">{{result.birthPlace}}</view>
      </view>
      <view class="profile-side">
        <view class="profile-status">{{result.professional && result.professional.strength ? result.professional.strength.status : '八字排盘'}}</view>
        <view class="profile-archive" bindtap="archiveCurrentCase" hover-class="tap-soft">存入命例</view>
      </view>
    </view>

    <view class="destiny-brief">
      <view class="brief-head">
        <view>
          <view class="brief-kicker">基础信息</view>
          <view class="brief-title">{{result.professional.chartSummary.oneLine}}</view>
        </view>
        <view class="brief-seal">{{result.dayMaster.text}}</view>
      </view>
      <view class="brief-grid">
        <view class="brief-item">
          <text>生肖</text>
          <text>{{result.detailProfile ? result.detailProfile.zodiac : ''}}</text>
        </view>
        <view class="brief-item">
          <text>节气</text>
          <text>{{result.solarTermInfoP0 && result.solarTermInfoP0.previous && result.solarTermInfoP0.previous.name}}</text>
        </view>
        <view class="brief-item">
          <text>五行</text>
          <text>{{result.fiveElementsP0 ? result.fiveElementsP0.dominant : ''}}</text>
        </view>
        <view class="brief-item">
          <text>空亡</text>
          <text>{{result.dayVoid ? result.dayVoid.text : '无'}}</text>
        </view>
      </view>
    </view>

    <view class="result-tabs">
      <view
        class="result-tab {{activeResultTabIndex === index ? 'active' : ''}}"
        wx:for="{{resultTabs}}"
        wx:key="*this"
        wx:for-index="index"
        bindtap="onResultTabChange"
        data-tab-index="{{index}}"
      >{{item}}</view>
    </view>

    <view wx:if="{{activeResultTabIndex === 0}}">
      <view class="song-overview">
        <view class="overview-title">八字排盘</view>
        <view class="pillar-grid">
          <view class="pillar-card" wx:for="{{songPlate.pillars}}" wx:key="label">
            <view class="pillar-label">{{item.label}}</view>
            <view class="pillar-core">{{item.stem}}{{item.branch}}</view>
            <view>十神：{{item.star}}</view>
            <view class="pillar-meta">纳音：{{item.nayin}}</view>
            <view class="pillar-meta">空亡：{{item.void}}</view>
            <view class="pillar-meta">藏干：{{item.hidden}}</view>
            <view class="pillar-hidden-lines">
              <view class="pillar-hidden-line" wx:for="{{item.levelStems}}" wx:key="level">
                <text class="hidden-role">{{item.level}}</text>
                <text class="hidden-stem-item">{{item.stem}}{{item.element}}</text>
                <text class="hidden-god">{{item.tenGod}}</text>
              </view>
            </view>
          </view>
        </view>
        <view class="detail-ribbon">
          <view class="detail-row" wx:for="{{songPlate.metaRows}}" wx:key="label">
            <view class="detail-label">{{item.label}}</view>
            <view class="detail-values">
              <text wx:for="{{item.values}}" wx:key="*this">{{item}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view wx:elif="{{activeResultTabIndex === 1}}">
      <view class="pro-summary">
        <view class="summary-main">{{result.professional.chartSummary.oneLine}}</view>
        <view class="summary-tags">
          <text class="summary-tag" wx:for="{{result.professional.chartSummary.tags}}" wx:key="*this">{{item}}</text>
        </view>
        <view class="summary-note">{{result.professional.chartSummary.caution}}</view>
      </view>
      <view class="pro-table-scroll">
        <view class="pro-table">
          <view class="pro-row pro-head-row">
            <view class="pro-label">柱位</view>
            <view class="pro-head-cell">十神</view>
            <view class="pro-head-cell">藏干</view>
            <view class="pro-head-cell">纳音</view>
            <view class="pro-head-cell">空亡</view>
            <view class="pro-head-cell">十神主文</view>
            <view class="pro-head-cell">空亡</view>
          </view>
          <view class="pro-row" wx:for="{{songPlate.pillars}}" wx:key="label">
            <view class="pro-label">{{item.label}}</view>
            <view class="pro-cell">{{item.star}}</view>
            <view class="pro-cell">{{item.hidden}}</view>
            <view class="pro-cell">{{item.nayin}}</view>
            <view class="pro-cell">{{item.void}}</view>
            <view class="pro-cell">{{item.spirits}}</view>
            <view class="pro-cell">{{item.subStar}}</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 大运流年 Tab -->
    <view wx:elif="{{activeResultTabIndex === 2}}">
      <!-- 当前位置提示 -->
      <view class="luck-current-tip">
        <view class="luck-current-label">当前查看</view>
        <view class="luck-current-text">
          {{professionalDetail.luckCycles[selectedLuckIndex].label}} · {{professionalDetail.selectedFlowYear.year}}年{{professionalDetail.selectedFlowYear.value}} · {{professionalDetail.selectedMonth.monthTitle}}月
        </view>
      </view>
      <view class="luck-scroll-hint">左右滑动查看完整大运、流年、流月</view>

      <!-- 大运横向时间轴 -->
      <scroll-view scroll-x class="luck-scroll-x" enable-flex>
        <view class="luck-row">
          <view class="luck-row-label">大运</view>
          <view class="luck-cycles-container">
            <view 
              wx:for="{{professionalDetail.luckCycles}}" 
              wx:key="label"
              class="luck-cycle-item {{item.active ? 'active' : ''}}"
              bindtap="onLuckTap"
              data-index="{{index}}"
            >
              <view class="luck-cycle-age">{{item.ageRange}}</view>
              <view class="luck-cycle-gz">{{item.value}}</view>
              <view class="luck-cycle-year">{{item.yearRange}}</view>
            </view>
          </view>
        </view>
      </scroll-view>

      <!-- 流年网格 -->
      <view class="flow-years-container">
        <view class="flow-years-row">
          <view class="flow-years-label">流年</view>
          <view class="flow-years-grid">
            <view class="flow-year-col" wx:for="{{professionalDetail.flowYears}}" wx:key="year">
              <view 
                wx:for="{{item.miniPillars}}" 
                wx:key="year"
                wx:for-item="yearItem"
                class="flow-year-item {{yearItem.active ? 'active' : ''}}"
                bindtap="onFlowYearItemTap"
                data-index="{{index}}"
                data-offset="{{yearItem.year - item.year}}"
              >
                <view class="flow-year-num">{{yearItem.year}}</view>
                <view class="flow-year-gz">{{yearItem.value}}</view>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- 流月横向时间轴 -->
      <scroll-view scroll-x class="luck-scroll-x" enable-flex>
        <view class="luck-row">
          <view class="luck-row-label">流月</view>
          <view class="luck-months-container">
            <view 
              wx:for="{{professionalDetail.flowMonths}}" 
              wx:key="monthTitle"
              class="luck-month-item {{item.active ? 'active' : ''}}"
              bindtap="onFlowMonthTap"
              data-index="{{index}}"
            >
              <view class="luck-month-term">{{item.monthTitle}}</view>
              <view class="luck-month-date">{{item.dateShort}}</view>
              <view class="luck-month-gz">{{item.value}}</view>
              <view class="luck-month-god">{{item.tenGod}}</view>
            </view>
          </view>
        </view>
      </scroll-view>

      <!-- 流月说明 -->
      <view class="flow-month-desc" wx:if="{{professionalDetail.selectedMonth}}">
        <view class="flow-month-title">{{professionalDetail.selectedMonth.monthTitle}}月 · {{professionalDetail.selectedMonth.value}} · {{professionalDetail.selectedMonth.tenGod}}</view>
        <view class="flow-month-text">{{professionalDetail.selectedMonth.influenceSummary}}</view>
      </view>
    </view>

    <view wx:else>
      <view class="focus-card quick-focus-card">
        <view class="focus-line">
          <text class="focus-index">1</text>
          <text>{{result.professional.chartSummary.oneLine}}</text>
        </view>
        <view class="focus-line">
          <text class="focus-index">2</text>
          <text>{{result.professional.usefulGod.usefulText}} / {{result.professional.usefulGod.avoidText}}</text>
        </view>
        <view class="focus-line">
          <text class="focus-index">3</text>
          <text>{{result.flowTriggerSummary.summary || '当前运势与流年提示'}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
