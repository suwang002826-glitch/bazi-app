<view class="page bazi-result-page">
  <view class="result-topbar">
    <view class="back-button" bindtap="goBack">返回</view>
    <view class="result-title">八字排盘</view>
    <view class="more-button"></view>
  </view>

  <view wx:if="{{!result}}" class="empty-state">
    <view class="empty-title">暂无排盘</view>
    <view class="empty-copy">请先填写出生信息，再生成八字排盘。</view>
    <button bindtap="goBack">返回填写</button>
  </view>

  <view wx:if="{{result}}" class="result-shell">
    <view class="bazi-profile">
      <view class="profile-zodiac-seal {{basicInfo.zodiacSeal.className}}">
        <image class="profile-zodiac-image" src="{{basicInfo.zodiacSeal.icon}}" mode="aspectFit" />
      </view>
      <view class="profile-main">
        <view class="profile-name">{{result.displayName}}</view>
        <view class="profile-time">阳历：{{result.solarTime}}</view>
        <view class="profile-lunar">农历：{{basicInfo.topLunar}}</view>
        <view class="profile-time">校准：{{result.adjustedSolarTime}}</view>
        <view class="profile-place">{{result.birthPlace}} · 东经 {{result.longitude}}°</view>
      </view>
      <view class="profile-side">
        <view class="profile-status">{{result.professional.strength.status}}</view>
        <view class="profile-archive" bindtap="archiveCurrentCase" hover-class="tap-soft">存档</view>
      </view>
    </view>

    <view class="result-tabs">
      <view class="result-tab {{activeResultTab === item ? 'active' : ''}}" wx:for="{{resultTabs}}" wx:key="*this" bindtap="onResultTabChange" data-tab="{{item}}">{{item}}</view>
    </view>

    <view wx:if="{{isInfoTab}}" class="basic-info-page">
      <view class="basic-info-hero">
        <view class="basic-info-seal {{basicInfo.zodiacSeal.className}}">
          <image class="basic-info-zodiac-image" src="{{basicInfo.zodiacSeal.icon}}" mode="aspectFit" />
        </view>
        <view class="basic-info-main">
          <view class="basic-info-name">{{basicInfo.name}}</view>
          <view class="basic-info-sub">命盘基础档案</view>
        </view>
        <view class="basic-info-chips">
          <view class="basic-info-chip" wx:for="{{basicInfo.chips}}" wx:key="*this">{{item}}</view>
        </view>
      </view>

      <view class="info-list-card">
        <view class="info-row" wx:for="{{basicInfo.rows}}" wx:key="label">
          <view class="info-label">{{item.label}}</view>
          <view class="info-value">{{item.value}}</view>
        </view>
      </view>

      <view class="info-section-title">命盘要点</view>
      <view class="info-highlight-grid">
        <view class="info-highlight-card" wx:for="{{basicInfo.highlights}}" wx:key="label">
          <view class="highlight-label">{{item.label}}</view>
          <view class="highlight-value">{{item.value}}</view>
        </view>
      </view>

      <view class="info-list-card compact-info-card">
        <view class="info-row" wx:for="{{basicInfo.palaceRows}}" wx:key="label">
          <view class="info-label">{{item.label}}</view>
          <view class="info-value">{{item.value}}</view>
        </view>
      </view>
    </view>

    <view wx:if="{{isBasicTab}}">
      <view class="plate-board">
        <view class="plate-head-row">
          <view class="plate-label-cell">日期</view>
          <view class="plate-head-cell" wx:for="{{songPlate.pillars}}" wx:key="label">{{item.label}}</view>
        </view>

        <view class="plate-row {{row.rowClass}}" wx:for="{{songPlate.tableRows}}" wx:for-item="row" wx:key="label">
          <view class="plate-label-cell">{{row.label}}</view>
          <view class="plate-cell" wx:for="{{row.cells}}" wx:for-item="cell" wx:key="index">
            <block wx:if="{{row.isMain}}">
              <view class="plate-main {{cell.className}}">{{cell.text}}</view>
            </block>
            <block wx:if="{{row.isHidden}}">
              <view class="plate-hidden-wrap">
                <view class="plate-hidden-item" wx:for="{{cell.hiddenItems}}" wx:for-item="hidden" wx:key="stem">
                  <text class="plate-hidden-stem {{hidden.className}}">{{hidden.stem}}</text>
                  <text class="plate-hidden-god">{{hidden.tenGod}}</text>
                </view>
              </view>
            </block>
            <block wx:if="{{row.isText}}">
              <view class="plate-text-line" wx:for="{{cell.lines}}" wx:for-item="line" wx:key="*this">{{line}}</view>
            </block>
            <block wx:if="{{row.isSpirit}}">
              <view class="plate-spirit-wrap">
                <text class="plate-spirit-name" wx:for="{{cell.spiritItems}}" wx:for-item="spirit" wx:key="name" bindtap="openSpiritInfo" data-name="{{spirit.name}}">{{spirit.name}}</text>
              </view>
            </block>
          </view>
        </view>
      </view>

      <view class="five-element-ratio">
        <view class="ratio-head">
          <view>
            <view class="ratio-kicker">五行比例</view>
            <view class="ratio-title">命盘五行分布</view>
          </view>
          <view class="ratio-daymaster">日主 {{result.dayMaster.text}}</view>
        </view>
        <view class="ratio-row" wx:for="{{result.distribution}}" wx:key="name">
          <view class="ratio-name">{{item.name}}</view>
          <view class="ratio-track">
            <view class="ratio-bar" style="width: {{item.percent}}%;"></view>
          </view>
          <view class="ratio-value">{{item.percent}}%</view>
        </view>
      </view>
    </view>

    <view wx:if="{{isProTab}}">
      <scroll-view class="pro-table-scroll" scroll-x="true">
        <view class="pro-table" style="width: {{professionalDetail.tableWidth}}rpx;">
          <view class="pro-row pro-head-row">
            <view class="pro-label">日期</view>
            <view class="pro-head-cell" wx:for="{{professionalDetail.columns}}" wx:for-item="col" wx:key="label">{{col.label}}</view>
          </view>
          <view class="pro-row {{row.className}}" wx:for="{{professionalDetail.rows}}" wx:for-item="row" wx:key="label">
            <view class="pro-label">{{row.label}}</view>
            <view class="pro-cell {{cell.displayClassName}}" wx:for="{{row.cells}}" wx:for-item="cell" wx:for-index="cellIndex" wx:key="cellIndex">
              <view wx:if="{{cell.hasRichLines}}" class="hidden-rich-wrap">
                <view wx:if="{{cell.hidden1Show}}" class="hidden-stem-line">
                  <text class="hidden-stem {{cell.hidden1Class}}">{{cell.hidden1Stem}}</text>
                  <text class="hidden-god">{{cell.hidden1God}}</text>
                </view>
                <view wx:if="{{cell.hidden2Show}}" class="hidden-stem-line">
                  <text class="hidden-stem {{cell.hidden2Class}}">{{cell.hidden2Stem}}</text>
                  <text class="hidden-god">{{cell.hidden2God}}</text>
                </view>
                <view wx:if="{{cell.hidden3Show}}" class="hidden-stem-line">
                  <text class="hidden-stem {{cell.hidden3Class}}">{{cell.hidden3Stem}}</text>
                  <text class="hidden-god">{{cell.hidden3God}}</text>
                </view>
              </view>
              <view wx:if="{{cell.lines.length}}">
                <text class="cell-line" wx:for="{{cell.lines}}" wx:for-item="line" wx:key="*this">{{line}}</text>
              </view>
              <view wx:if="{{cell.text}}">
                <text class="cell-main">{{cell.text}}</text>
                <text wx:if="{{cell.elementIcon}}" class="element-icon">{{cell.elementIcon}}</text>
              </view>
            </view>
          </view>
        </view>
      </scroll-view>

      <view class="current-flow-card">
        <view class="current-flow-kicker">当前查看</view>
        <view class="current-flow-title">{{professionalDetail.activeLuck.yearRange}} {{professionalDetail.activeLuck.value}}大运 · {{professionalDetail.selectedFlowYear.year}} {{professionalDetail.selectedFlowYear.value}}流年 · {{professionalDetail.selectedMonth.monthTitle}} {{professionalDetail.selectedMonth.value}}流月</view>
        <view class="current-flow-hint">左右滑动查看完整大运、流年、流月</view>
      </view>

      <view class="flow-block with-fade">
        <view class="side-label"><text>大</text><text>运</text></view>
        <scroll-view class="flow-scroll" scroll-x="true" enhanced="true" show-scrollbar="false">
          <view class="luck-strip" style="width: {{professionalDetail.luckStripWidth}}rpx; min-width: {{professionalDetail.luckStripWidth}}rpx;">
            <view class="luck-cell" wx:for="{{professionalDetail.luckCycles}}" wx:key="yearRange" bindtap="onLuckTap" data-index="{{index}}">
              <view class="luck-year">{{item.yearStart}}</view>
              <view class="luck-age">{{item.ageRange}}</view>
              <view class="luck-value">{{item.stem}}{{item.branch}}</view>
            </view>
          </view>
        </scroll-view>
      </view>

      <view class="flow-block with-fade">
        <view class="flow-side"><view class="flow-side-top">始于</view><view class="side-label"><text>流</text><text>年</text></view><view class="flow-side-bottom">止于</view></view>
        <scroll-view class="flow-scroll" scroll-x="true" enhanced="true" show-scrollbar="false">
          <view class="flow-year-table" style="width: {{professionalDetail.flowYearStripWidth}}rpx; min-width: {{professionalDetail.flowYearStripWidth}}rpx;">
            <view class="flow-year-col {{item.active ? 'active' : ''}}" wx:for="{{professionalDetail.flowYears}}" wx:key="year" bindtap="onFlowYearTap" data-index="{{index}}">
              <view class="flow-year">{{item.year}}</view>
              <view class="flow-year-line {{line.active ? 'active' : ''}}" wx:for="{{item.miniPillars}}" wx:for-item="line" wx:for-index="lineIndex" wx:key="year" catchtap="onFlowYearItemTap" data-index="{{index}}" data-offset="{{lineIndex}}">
                <text class="flow-year-line-year">{{line.year}}</text>
                <text class="flow-year-line-value">{{line.value}}</text>
              </view>
              <view class="flow-year-end">{{item.endYear}}</view>
            </view>
          </view>
        </scroll-view>
      </view>

      <view class="flow-block with-fade">
        <view class="side-label"><text>流</text><text>月</text></view>
        <scroll-view class="flow-scroll" scroll-x="true" enhanced="true" show-scrollbar="false">
          <view class="month-strip" style="width: {{professionalDetail.flowMonthStripWidth}}rpx; min-width: {{professionalDetail.flowMonthStripWidth}}rpx;">
            <view class="month-cell" wx:for="{{professionalDetail.flowMonths}}" wx:key="label" bindtap="onFlowMonthTap" data-index="{{index}}">
              <view class="month-label">{{item.monthTitle}}</view>
              <view class="month-date">{{item.dateShort}}</view>
              <view class="month-value">{{item.value}}</view>
              <view class="month-god">{{item.tenGod}}</view>
            </view>
          </view>
        </scroll-view>
      </view>

      <view class="selected-flow-card" wx:if="{{professionalDetail.selectedMonth}}">
        <view class="selected-flow-title">{{professionalDetail.selectedMonth.label}} · {{professionalDetail.selectedMonth.value}} · {{professionalDetail.selectedMonth.tenGod}}</view>
        <view class="selected-flow-line">{{professionalDetail.selectedMonth.influenceSummary}}</view>
        <view class="selected-flow-line">合冲刑害：{{professionalDetail.selectedMonth.interactionSummary}}</view>
      </view>

      <view class="element-state-row"><text wx:for="{{professionalDetail.elementStates}}" wx:key="*this">| {{item}} |</text></view>
      <view class="action-row"><button class="ghost-action" bindtap="openGanzhiDiagram">干支关系</button><button class="ghost-action small" bindtap="openAiCommand">白话解析</button></view>
      <view class="relation-panel"><view class="relation-line" wx:for="{{professionalDetail.relationLines}}" wx:key="label"><text>{{item.label}}：</text>{{item.text}}</view></view>

      <view class="spirit-section-title">四柱神煞</view>
      <view class="spirit-list"><view class="spirit-line" wx:for="{{professionalDetail.pillarSpirits}}" wx:key="value"><text class="spirit-pill">{{item.value}}</text><view class="spirit-names" wx:if="{{item.names.length}}"><text class="spirit-name-chip" wx:for="{{item.names}}" wx:for-item="name" wx:key="*this" bindtap="openSpiritInfo" data-name="{{name}}">{{name}}</text></view></view></view>

      <view class="spirit-section-title">大运神煞</view>
      <view class="spirit-list"><view class="spirit-line" wx:for="{{professionalDetail.luckSpirits}}" wx:key="value"><text class="spirit-pill">{{item.value}}</text><view class="spirit-names"><text class="spirit-name-chip" wx:for="{{item.names}}" wx:for-item="name" wx:key="*this" bindtap="openSpiritInfo" data-name="{{name}}">{{name}}</text></view></view></view>

      <view class="sub-heading">格局与旺衰</view>
      <view class="profile-card featured-profile"><view class="profile-title">{{result.professional.pattern.name}}</view><view class="muted">{{result.professional.pattern.basis}}</view><view class="strength-line">旺衰 {{result.professional.strength.status}} · 扶身 {{result.professional.strength.ratio}}%</view><view class="muted basis-line" wx:for="{{result.professional.strength.basis}}" wx:key="*this">{{item}}</view></view>
      <view class="sub-heading">喜用神参考</view>
      <view class="profile-card useful-card"><view><view class="profile-title">喜用 {{result.professional.usefulGod.usefulText}}</view><view class="muted">{{result.professional.usefulGod.basis}}</view></view><view class="avoid-block">忌 {{result.professional.usefulGod.avoidText}}</view></view>
    </view>

    <view wx:if="{{isAnalysisTab}}">
      <view class="focus-card quick-focus-card"><view class="sub-heading compact-heading">先看这三点</view><view class="focus-line"><text class="focus-index">1</text><text>{{result.professional.chartSummary.oneLine}}</text></view><view class="focus-line"><text class="focus-index">2</text><text>喜用参考 {{result.professional.usefulGod.usefulText}}，忌 {{result.professional.usefulGod.avoidText}}。这是趋势提示，不是绝对定论。</text></view><view class="focus-line"><text class="focus-index">3</text><text>{{result.flowTriggerSummary.summary}}</text></view></view>
      <view class="sub-heading">三层解读</view>
      <view class="layer-card" wx:for="{{result.interpretationLayers}}" wx:key="title"><view class="layer-title">{{item.title}}</view><view class="layer-row"><text class="layer-label">命理原文</text><text>{{item.original}}</text></view><view class="layer-row"><text class="layer-label">白话解释</text><text>{{item.plain}}</text></view><view class="layer-row"><text class="layer-label">修身建议</text><text>{{item.action}}</text></view></view>
      <view class="result-card reading-card"><view class="result-line muted">{{result.summary}}</view><view class="engine-list"><view class="engine-item" wx:for="{{result.engineInfo}}" wx:key="*this">{{item}}</view></view><view class="result-line muted">{{result.aiText}}</view></view>
    </view>
  </view>

  <view wx:if="{{spiritModal.visible}}" class="spirit-modal-mask" catchtap="closeSpiritInfo">
    <view class="spirit-modal" catchtap="noop"><view class="spirit-modal-head"><view class="spirit-figure-card"><view class="spirit-figure-symbol">{{spiritModal.figure}}</view><view class="spirit-figure-caption">星曜符牌</view></view><view class="spirit-modal-title-block"><view class="spirit-modal-kicker">{{spiritModal.category}}</view><view class="spirit-modal-title">{{spiritModal.title}}</view><view class="spirit-modal-source">传统子平神煞 · 测试版释义</view></view></view><view class="spirit-modal-section"><view class="spirit-modal-label">含义</view><view class="spirit-modal-copy">{{spiritModal.meaning}}</view></view><view class="spirit-modal-section"><view class="spirit-modal-label">命盘依据</view><view class="spirit-modal-copy">{{spiritModal.basis}}</view></view><view class="spirit-modal-section"><view class="spirit-modal-label">使用提醒</view><view class="spirit-modal-copy">{{spiritModal.advice}}</view></view><button class="spirit-modal-close" bindtap="closeSpiritInfo">知道了</button></view>
  </view>
</view>
