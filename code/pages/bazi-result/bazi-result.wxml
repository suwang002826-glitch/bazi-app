п»ҝ<view class="page bazi-result-page">
  <view class="result-topbar">
    <view class="back-button" bindtap="goBack">йҲҘ?/view>
    <view class="result-title">йҚҸоӮўз“§йҺәжҺ”жҙҸ</view>
    <view class="more-button"></view>
  </view>

  <view wx:if="{{!result}}" class="empty-state">
    <view class="empty-title">йҸҶеӮӣжЈӨйҺәжҺ”жҙҸ</view>
    <view class="empty-copy">з’Үеі°еҺӣжҝүоӮўе•“йҚ‘иҷ№ж•“ж·Үв„ғдј…й”ӣеұҪе•ҖйҗўзҶёеһҡйҚҸоӮўз“§йҺәжҺ”жҙҸйҠҶ?/view>
    <button bindtap="goBack">жқ©ж–ҝжҙ–жҝүоӮўе•“</button>
  </view>

  <view wx:else class="result-shell">
    <view class="bazi-profile">
      <view class="profile-seal">{{result.dayMaster.stem}}</view>
      <view class="profile-main">
        <view class="profile-name">{{result.displayName || result.title}}</view>
        <view class="profile-time">й—ғеҶІе·»й”ӣжӯҝ{result.solarTime}}</view>
        <view class="profile-time">йҸҚвҖіеҷҜй”ӣжӯҝ{result.adjustedSolarTime}}</view>
        <view class="profile-place">{{result.birthPlace}} и·Ҝ ж¶“ж»…зІЎ {{result.longitude}}жҺі</view>
      </view>
      <view class="profile-side">
        <view class="profile-status">{{result.professional.strength.status}}</view>
        <view class="profile-archive" bindtap="archiveCurrentCase" hover-class="tap-soft">зҖӣжЁ»гҖӮ</view>
      </view>
    </view>

    <view class="result-tabs">
      <view
        class="result-tab {{activeResultTab === item ? 'active' : ''}}"
        wx:for="{{resultTabs}}"
        wx:key="*this"
        bindtap="onResultTabChange"
        data-tab="{{item}}"
      >{{item}}</view>
    </view>

    <view wx:if="{{activeResultTab === 'йҚ©зғҳж№°йҚӣз•ҢжҙҸ'}}">
      <view class="song-overview">
        <view class="overview-title">йҚҘж¶ҷз…ҙйҚӣз•ҢжҙҸ</view>
        <view class="overview-copy">жө гғҘеӢҫйҠҶдҪ№ж№ҖйҠҶдҪ№жЈ©йҠҶдҪ№жӨӮйҚ’е——еһӘйҚӣе ўе№Үй”ӣеұҪеҺӣйҗӘе¬¬зІЁйҸӢеӢ¶зҙқйҚҗе¶Үж№…зјҒе—ӣгҖҚйҠҶ?/view>
        <view class="pillar-grid">
          <view class="pillar-card" wx:for="{{songPlate.pillars}}" wx:key="label">
            <view class="pillar-label">{{item.label}}</view>
            <view class="pillar-star">{{item.star}}</view>
            <view class="pillar-core">
              <text class="pillar-stem">{{item.stem}}</text>
              <text class="pillar-branch">{{item.branch}}</text>
            </view>
            <view class="pillar-meta">
              <text>{{item.hidden}}</text>
              <text>{{item.subStar}}</text>
            </view>
          </view>
        </view>

        <view class="detail-ribbon">
          <view class="detail-row" wx:for="{{songPlate.metaRows}}" wx:key="label">
            <view class="detail-label">{{item.label}}</view>
            <view class="detail-values">
              <text wx:for="{{item.values}}" wx:for-item="value" wx:key="*this">{{value}}</text>
            </view>
          </view>
        </view>

        <view class="spirit-ribbon">
          <view class="detail-label">з»ҒзӮөеҺј</view>
          <view class="spirit-values">
            <view class="spirit-basic-line" wx:for="{{songPlate.pillars}}" wx:key="label">
              <text class="spirit-basic-label">{{item.label}}й”ӣ?/text>
              <view class="spirit-chip-row" wx:if="{{item.spiritItems.length}}">
                <text
                  class="spirit-name-chip"
                  wx:for="{{item.spiritItems}}"
                  wx:for-item="spirit"
                  wx:key="name"
                  bindtap="openSpiritInfo"
                  data-name="{{spirit.name}}"
                >{{spirit.name}}</text>
              </view>
              <text wx:else class="spirit-empty">йҸҲоҒҮоқҶз”Ҝе“Ҙж•Өз»ҒзӮөеҺјйҚҸгғҰз…ҙ</text>
            </view>
          </view>
        </view>
      </view>

      <view class="five-element-ratio">
        <view class="ratio-head">
          <view>
            <view class="ratio-kicker">жөңж—Үо”‘е§Јж–ҫз·Ҙ</view>
            <view class="ratio-title">йҚӣз•ҢжҙҸжөңж—Үо”‘йҚ’е——з«·</view>
          </view>
          <view class="ratio-daymaster">йҸғгғӨеҜҢ {{result.dayMaster.text}}</view>
        </view>
        <view class="ratio-row" wx:for="{{result.distribution}}" wx:key="name">
          <view class="ratio-name">{{item.name}}</view>
          <view class="ratio-track">
            <view class="ratio-bar" style="width: {{item.percent}}%;"></view>
          </view>
          <view class="ratio-value">{{item.percent}}%</view>
        </view>
      </view>

    </view>

    <view wx:elif="{{activeResultTab === 'ж¶“ж’Із¬ҹзјҒе—ҷжҙҸ'}}">
      <view class="pro-summary">
        <view class="summary-main">{{result.professional.chartSummary.oneLine}}</view>
        <view class="summary-tags">
          <text class="summary-tag" wx:for="{{result.professional.chartSummary.tags}}" wx:key="*this">{{item}}</text>
        </view>
        <view class="summary-note">{{result.professional.chartSummary.caution}}</view>
      </view>

      <scroll-view class="pro-table-scroll" scroll-x>
        <view class="pro-table" style="width: {{professionalDetail.tableWidth}}rpx;">
          <view class="pro-row pro-head-row">
            <view class="pro-label">йҸғгғҰж№Ў</view>
            <view class="pro-head-cell" wx:for="{{professionalDetail.columns}}" wx:for-item="col" wx:key="label">{{col.label}}</view>
          </view>
          <view
            class="pro-row {{row.strong ? 'strong-row' : ''}} {{row.highlight ? 'spirit-row' : ''}}"
            wx:for="{{professionalDetail.rows}}"
            wx:for-item="row"
            wx:key="label"
          >
            <view class="pro-label">{{row.label}}</view>
            <view
              class="pro-cell {{cell.large ? 'large-cell' : ''}} {{cell.className}} {{cell.hasRichLines ? 'hidden-rich-cell' : ''}}"
              wx:for="{{row.cells}}"
              wx:for-item="cell"
              wx:for-index="cellIndex"
              wx:key="cellIndex"
            >
              <block wx:if="{{cell.hasRichLines}}">
                <view wx:if="{{cell.hidden1Show}}" class="hidden-stem-line hidden-line-1">
                  <text class="hidden-stem {{cell.hidden1Class}}">{{cell.hidden1Stem}}</text>
                  <text class="hidden-god">{{cell.hidden1God}}</text>
                </view>
                <view wx:if="{{cell.hidden2Show}}" class="hidden-stem-line hidden-line-2">
                  <text class="hidden-stem {{cell.hidden2Class}}">{{cell.hidden2Stem}}</text>
                  <text class="hidden-god">{{cell.hidden2God}}</text>
                </view>
                <view wx:if="{{cell.hidden3Show}}" class="hidden-stem-line hidden-line-3">
                  <text class="hidden-stem {{cell.hidden3Class}}">{{cell.hidden3Stem}}</text>
                  <text class="hidden-god">{{cell.hidden3God}}</text>
                </view>
                <text wx:if="{{!cell.hidden1Show}}" class="cell-main">йҲҘ?/text>
              </block>
              <block wx:elif="{{cell.lines.length}}">
                <text class="cell-line" wx:for="{{cell.lines}}" wx:for-item="line" wx:key="*this">{{line}}</text>
              </block>
              <block wx:else>
                <text class="cell-main">{{cell.text}}</text>
                <text wx:if="{{cell.elementIcon}}" class="element-icon">{{cell.elementIcon}}</text>
              </block>
            </view>
          </view>
        </view>
      </scroll-view>

      <view class="current-flow-card">
        <view class="current-flow-kicker">иӨ°ж’іеў йҸҢгғ§ж№…</view>
        <view class="current-flow-title">
          {{professionalDetail.activeLuck.yearRange}} {{professionalDetail.activeLuck.value}}жҫ¶СҶз№Қ и·Ҝ {{professionalDetail.selectedFlowYear.year}} {{professionalDetail.selectedFlowYear.value}}еЁҙдҪёеӢҫ и·Ҝ {{professionalDetail.selectedMonth.monthTitle}} {{professionalDetail.selectedMonth.value}}еЁҙдҪ№ж№Җ
        </view>
        <view class="current-flow-hint">е®ёп№ҖеҪёе©ҠжҲқе§©йҸҢгғ§ж№…зҖ№еұҫжҡЈжҫ¶СҶз№ҚйҠҶдҪ№зҘҰйӘһж·¬вӮ¬дҪ№зҘҰйҸҲ?/view>
      </view>

      <view class="flow-block with-fade">
        <view class="side-label">
          <text>жҫ¶?/text>
          <text>жқ©?/text>
        </view>
        <scroll-view class="flow-scroll" scroll-x="true" enhanced="true" show-scrollbar="false">
          <view class="luck-strip" style="width: {{professionalDetail.luckStripWidth}}rpx; min-width: {{professionalDetail.luckStripWidth}}rpx;">
            <view
              class="luck-cell {{item.active ? 'active' : ''}}"
              wx:for="{{professionalDetail.luckCycles}}"
              wx:key="yearRange"
              bindtap="onLuckTap"
              data-index="{{index}}"
            >
              <view class="luck-year">{{item.yearStart}}</view>
              <view class="luck-age">{{item.ageRange}}</view>
              <view class="luck-value">{{item.stem}}{{item.branch}}</view>
            </view>
          </view>
        </scroll-view>
      </view>

      <view class="flow-block with-fade">
        <view class="flow-side">
          <view class="flow-side-top">жҝ®е¬©з°¬</view>
          <view class="side-label">
            <text>еЁҙ?/text>
            <text>йӘһ?/text>
          </view>
          <view class="flow-side-bottom">е§қоқӯз°¬</view>
        </view>
        <scroll-view class="flow-scroll" scroll-x="true" enhanced="true" show-scrollbar="false">
          <view class="flow-year-table" style="width: {{professionalDetail.flowYearStripWidth}}rpx; min-width: {{professionalDetail.flowYearStripWidth}}rpx;">
            <view
              class="flow-year-col {{item.active ? 'active' : ''}}"
              wx:for="{{professionalDetail.flowYears}}"
              wx:key="year"
              bindtap="onFlowYearTap"
              data-index="{{index}}"
            >
              <view class="flow-year">{{item.year}}</view>
              <view
                class="flow-year-line {{line.active ? 'active' : ''}}"
                wx:for="{{item.miniPillars}}"
                wx:for-item="line"
                wx:for-index="lineIndex"
                wx:key="year"
                catchtap="onFlowYearItemTap"
                data-index="{{index}}"
                data-offset="{{lineIndex}}"
              >
                <text class="flow-year-line-year">{{line.year}}</text>
                <text class="flow-year-line-value">{{line.value}}</text>
              </view>
              <view class="flow-year-end">{{item.endYear}}</view>
            </view>
          </view>
        </scroll-view>
      </view>

      <view class="flow-block with-fade">
        <view class="side-label">
          <text>еЁҙ?/text>
          <text>йҸҲ?/text>
        </view>
        <scroll-view class="flow-scroll" scroll-x="true" enhanced="true" show-scrollbar="false">
          <view class="month-strip" style="width: {{professionalDetail.flowMonthStripWidth}}rpx; min-width: {{professionalDetail.flowMonthStripWidth}}rpx;">
            <view
              class="month-cell {{item.active ? 'active' : ''}}"
              wx:for="{{professionalDetail.flowMonths}}"
              wx:key="label"
              bindtap="onFlowMonthTap"
              data-index="{{index}}"
            >
              <view class="month-label">{{item.monthTitle}}</view>
              <view class="month-date">{{item.dateShort}}</view>
              <view class="month-value">{{item.value}}</view>
              <view class="month-god">{{item.tenGod}}</view>
            </view>
          </view>
        </scroll-view>
      </view>

      <view class="selected-flow-card" wx:if="{{professionalDetail.selectedMonth}}">
        <view class="selected-flow-title">{{professionalDetail.selectedMonth.label}} и·Ҝ {{professionalDetail.selectedMonth.value}} и·Ҝ {{professionalDetail.selectedMonth.tenGod}}</view>
        <view class="selected-flow-line">{{professionalDetail.selectedMonth.influenceSummary}}</view>
        <view class="selected-flow-line">йҚҡе қе•ҝйҚ’жҲқоҶҠй”ӣжӯҝ{professionalDetail.selectedMonth.interactionSummary}}</view>
      </view>

      <view class="element-state-row">
        <text wx:for="{{professionalDetail.elementStates}}" wx:key="*this">| {{item}} |</text>
      </view>

      <view class="action-row">
        <button class="ghost-action" bindtap="openGanzhiDiagram">йӘһеҸүж•®йҚҸеҙҮйғҙ йҲҘ?/button>
        <button class="ghost-action small" bindtap="openAiCommand">йҗ§еҖҹзҳҪз‘ҷпҪҶзҖҪ йҲҘ?/button>
      </view>

      <view class="relation-panel">
        <view class="relation-line" wx:for="{{professionalDetail.relationLines}}" wx:key="label">
          <text>{{item.label}}й”ӣ?/text>{{item.text}}
        </view>
      </view>

      <view class="spirit-section-title">йҚҘж¶ҷз…ҙз»ҒзӮөеҺј</view>
      <view class="spirit-list">
        <view class="spirit-line" wx:for="{{professionalDetail.pillarSpirits}}" wx:key="value">
          <text class="spirit-pill">{{item.value}}</text>
          <view class="spirit-names" wx:if="{{item.names.length}}">
            <text
              class="spirit-name-chip"
              wx:for="{{item.names}}"
              wx:for-item="name"
              wx:key="*this"
              bindtap="openSpiritInfo"
              data-name="{{name}}"
            >{{name}}</text>
          </view>
          <text wx:else class="spirit-empty">йҸҲоҒҮоқҶз”Ҝе“Ҙж•Өз»ҒзӮөеҺјйҚҸгғҰз…ҙ</text>
        </view>
      </view>

      <view class="spirit-section-title">жҫ¶СҶз№Қз»ҒзӮөеҺј</view>
      <view class="spirit-list">
        <view class="spirit-line" wx:for="{{professionalDetail.luckSpirits}}" wx:key="value">
          <text class="spirit-pill {{item.active ? 'active' : ''}}">{{item.value}}</text>
          <view class="spirit-names">
            <text
              class="spirit-name-chip"
              wx:for="{{item.names}}"
              wx:for-item="name"
              wx:key="*this"
              bindtap="openSpiritInfo"
              data-name="{{name}}"
            >{{name}}</text>
          </view>
        </view>
      </view>

      <view class="sub-heading">йҸҚз…Һзң¬ж¶“еәўжӨҮзҗӣ?/view>
      <view class="profile-card featured-profile">
        <view class="profile-title">{{result.professional.pattern.name}}</view>
        <view class="muted">{{result.professional.pattern.basis}}</view>
        <view class="strength-line">йҸғйёҝвҖң {{result.professional.strength.status}} и·Ҝ йҺөжғ°йҹ© {{result.professional.strength.ratio}}%</view>
        <view class="muted basis-line" wx:for="{{result.professional.strength.basis}}" wx:key="*this">{{item}}</view>
      </view>

      <view class="sub-heading">йҚ ж»…ж•Өз»ҒзӮІеј¬й‘°?/view>
      <view class="profile-card useful-card">
        <view>
          <view class="profile-title">йҚ ж»…ж•Ө {{result.professional.usefulGod.usefulText}}</view>
          <view class="muted">{{result.professional.usefulGod.basis}}</view>
        </view>
        <view class="avoid-block">и№Ү?{{result.professional.usefulGod.avoidText}}</view>
      </view>

      <view class="sub-heading">й‘іеәЎеҺ“йҠҶдҪёжҮЎзҖ№оӮЎз¬Ңйҹ¬оӮўоҶӮ</view>
      <view class="profile-card">
        <view class="profile-title">й‘іеәЎеҺ“ {{result.detailProfile.fetalOrigin.value}} и·Ҝ {{result.detailProfile.fetalOrigin.nayin}}</view>
        <view class="muted">{{result.detailProfile.fetalOrigin.basis}}</view>
        <view class="muted detail-note">йҚӣи—үоҶӮ {{result.detailProfile.palaceProfile.life.value}} и·Ҝ йҹ¬оӮўоҶӮ {{result.detailProfile.palaceProfile.body.value}}</view>
      </view>
    </view>

    <view wx:else>
      <view class="focus-card quick-focus-card">
        <view class="sub-heading compact-heading">йҚҸе ўж№…жқ©ж¬Һз¬Ғйҗҗ?/view>
        <view class="focus-line">
          <text class="focus-index">1</text>
          <text>{{result.professional.chartSummary.oneLine}}</text>
        </view>
        <view class="focus-line">
          <text class="focus-index">2</text>
          <text>йҚ ж»…ж•ӨйҚҷеӮқвӮ¬?{{result.professional.usefulGod.usefulText}}й”ӣеұҪз№ү {{result.professional.usefulGod.avoidText}}йҠҶеӮқз№–йҸ„оҲқз§јйҚ”жҢҺеҪҒз»ҖзҢҙзҙқж¶“е¶Ҷж§ёзјҒжҝҶоҮ®зҖ№ж°іоҶ‘йҠҶ?/text>
        </view>
        <view class="focus-line">
          <text class="focus-index">3</text>
          <text>{{result.flowTriggerSummary.summary || 'иӨ°ж’іеў еЁҙдҪҪз№ҚйҸҲоҒҮоқҶжҘӮжЁ№зҙӯйҚҸе ўйӘҮз‘ҷп№ҖеҪӮйҗҗзҷёзҙқй–«еӮҡжӮҺйҚҸе ўж№…жҫ¶СҶз№Қж¶“еәЎеё«зҒһвӮ¬зјҒж’ҙзҖҜйҠҶ?}}</text>
        </view>
      </view>

      <view class="sub-heading">ж¶“еӨҠзң°з‘ҷпҪҲоҮ°</view>
      <view class="layer-card" wx:for="{{result.interpretationLayers}}" wx:key="title">
        <view class="layer-title">{{item.title}}</view>
        <view class="layer-row">
          <text class="layer-label">йҚӣз•ҢжӮҠйҚҳзҶёжһғ</text>
          <text>{{item.original}}</text>
        </view>
        <view class="layer-row">
          <text class="layer-label">йҗ§еҖҹзҳҪз‘ҷпҪүеҷҙ</text>
          <text>{{item.plain}}</text>
        </view>
        <view class="layer-row">
          <text class="layer-label">ж·ҮоҶҝйҹ©еҜӨйёҝоҶ…</text>
          <text>{{item.action}}</text>
        </view>
      </view>

      <view class="result-card reading-card">
        <view class="result-line muted">{{result.summary}}</view>
        <view class="engine-list">
          <view class="engine-item" wx:for="{{result.engineInfo}}" wx:key="*this">{{item}}</view>
        </view>
        <view class="result-line muted">{{result.aiText}}</view>
      </view>
    </view>
  </view>

  <view wx:if="{{spiritModal.visible}}" class="spirit-modal-mask" catchtap="closeSpiritInfo">
    <view class="spirit-modal" catchtap="noop">
      <view class="spirit-modal-head">
        <view class="spirit-figure-card">
          <view class="spirit-figure-symbol">{{spiritModal.figure}}</view>
          <view class="spirit-figure-caption">йҸ„зҶёжҙ”з»—пёҫеўқ</view>
        </view>
        <view class="spirit-modal-title-block">
          <view class="spirit-modal-kicker">{{spiritModal.category}}</view>
          <view class="spirit-modal-title">{{spiritModal.title}}</view>
          <view class="spirit-modal-source">жөјзҠөзІәзҖӣж„¬й’©з»ҒзӮөеҺј и·Ҝ еЁҙе¬ӯзҳҜйҗ—е Ҙеҷҙж¶”?/view>
        </view>
      </view>
      <view class="spirit-modal-section">
        <view class="spirit-modal-label">йҚҡоӮЎз®ҹ</view>
        <view class="spirit-modal-copy">{{spiritModal.meaning}}</view>
      </view>
      <view class="spirit-modal-section">
        <view class="spirit-modal-label">йҚӣз•ҢжҙҸжёҡжҝҮеөҒ</view>
        <view class="spirit-modal-copy">{{spiritModal.basis}}</view>
      </view>
      <view class="spirit-modal-section">
        <view class="spirit-modal-label">жөЈи·Ёж•ӨйҺ»ж„°е•Ӣ</view>
        <view class="spirit-modal-copy">{{spiritModal.advice}}</view>
      </view>
      <button class="spirit-modal-close" bindtap="closeSpiritInfo">йҗӯгғ©дәҫжөң?/button>
    </view>
  </view>
</view>



