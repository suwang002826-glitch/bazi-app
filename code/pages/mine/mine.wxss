.mine-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at 90% 0%, rgba(33, 91, 103, .24), transparent 36%),
    linear-gradient(180deg, #071016 0%, #071823 58%, #08131a 100%);
}

.profile-card {
  overflow: hidden;
  background: rgba(250, 253, 250, .9);
}

.profile-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.avatar {
  flex: 0 0 auto;
  width: 96rpx;
  height: 96rpx;
  border: 1rpx solid rgba(202, 183, 112, .42);
  border-radius: 50%;
  background: #071823;
  color: #f8fffc;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 94rpx;
  text-align: center;
}

.profile-main {
  min-width: 0;
  flex: 1;
}

.nickname {
  margin-bottom: 6rpx;
  color: #061d1f;
  font-size: 34rpx;
  font-weight: 900;
}

.profile-meta {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-top: 22rpx;
}

.profile-meta view {
  min-width: 0;
  padding: 14rpx 8rpx;
  border-radius: 14rpx;
  background: rgba(230, 240, 236, .66);
  text-align: center;
}

.profile-meta text {
  display: block;
}

.profile-meta text:first-child {
  color: #6d5830;
  font-size: 22rpx;
  font-weight: 900;
}

.profile-meta text:last-child {
  margin-top: 4rpx;
  color: #183742;
  font-size: 28rpx;
  font-weight: 900;
}

.profile-note {
  margin-top: 18rpx;
}

.archive-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.tappable-row {
  transition: opacity .16s ease, transform .16s ease;
}

.tap-active {
  opacity: .72;
  transform: scale(.995);
}

.archive-copy {
  min-width: 0;
  flex: 1;
}

.entry-arrow {
  flex: 0 0 auto;
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  background: rgba(27, 111, 104, .12);
  color: #1f5b70;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 52rpx;
  text-align: center;
}

.history-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(60, 120, 115, .16);
}

.history-row:last-child {
  border-bottom: 0;
}

.history-content {
  min-width: 0;
  flex: 1;
}

.history-title {
  margin-bottom: 8rpx;
  color: #061d1f;
  font-size: 30rpx;
  font-weight: 900;
}

.history-summary {
  display: -webkit-box;
  margin-top: 6rpx;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.small-arrow {
  width: 44rpx;
  height: 44rpx;
  font-size: 34rpx;
  line-height: 38rpx;
}

.clear-btn {
  margin-top: 20rpx;
}

.extra {
  margin-top: 14rpx;
}

.empty-text {
  padding: 22rpx;
  border-radius: 14rpx;
  background: rgba(230, 240, 236, .62);
  color: #365b58;
  font-size: 25rpx;
  line-height: 1.65;
}
