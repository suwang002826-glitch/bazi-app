.mine-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #07080e 0%, #101127 56%, #07080e 100%);
  color: #f2f0e4;
}

.mine-page .section {
  border: 1rpx solid rgba(217, 191, 113, .14);
  border-radius: 18rpx;
  background:
    linear-gradient(145deg, rgba(242, 240, 228, .075), rgba(242, 240, 228, .025)),
    rgba(18, 21, 50, .92);
  box-shadow:
    inset 0 1rpx 0 rgba(242, 240, 228, .08),
    0 20rpx 44rpx rgba(0, 0, 0, .28);
}

.mine-page .section-title {
  color: #f2f0e4;
}

.mine-page .section-kicker {
  border-color: rgba(217, 191, 113, .20);
  background: rgba(217, 191, 113, .10);
  color: #d9bf71;
}

.mine-page .muted {
  color: rgba(242, 240, 228, .66);
}

.profile-card {
  overflow: hidden;
}

.profile-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.avatar {
  flex: 0 0 auto;
  width: 96rpx;
  height: 96rpx;
  border: 1rpx solid rgba(202, 183, 112, .42);
  border-radius: 50%;
  background: rgba(7, 8, 14, .72);
  color: #d9bf71;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 94rpx;
  text-align: center;
}

.profile-main {
  min-width: 0;
  flex: 1;
}

.nickname {
  margin-bottom: 6rpx;
  color: #f2f0e4;
  font-size: 34rpx;
  font-weight: 900;
}

.profile-meta {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-top: 22rpx;
}

.profile-meta view {
  min-width: 0;
  padding: 14rpx 8rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(242, 240, 228, .06);
  background: rgba(7, 8, 14, .34);
  text-align: center;
}

.profile-meta text {
  display: block;
}

.profile-meta text:first-child {
  color: rgba(242, 240, 228, .48);
  font-size: 22rpx;
  font-weight: 900;
}

.profile-meta text:last-child {
  margin-top: 4rpx;
  color: #d9bf71;
  font-size: 28rpx;
  font-weight: 900;
}

.profile-note {
  margin-top: 18rpx;
}

.archive-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.tappable-row {
  transition: opacity .16s ease, transform .16s ease;
}

.tap-active {
  opacity: .72;
  transform: scale(.995);
}

.archive-copy {
  min-width: 0;
  flex: 1;
}

.entry-arrow {
  flex: 0 0 auto;
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(217, 191, 113, .16);
  background: rgba(217, 191, 113, .10);
  color: #d9bf71;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 52rpx;
  text-align: center;
}

.history-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(242, 240, 228, .08);
}

.history-row:last-child {
  border-bottom: 0;
}

.history-content {
  min-width: 0;
  flex: 1;
}

.history-title {
  margin-bottom: 8rpx;
  color: #f2f0e4;
  font-size: 30rpx;
  font-weight: 900;
}

.history-summary {
  display: -webkit-box;
  margin-top: 6rpx;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.small-arrow {
  width: 44rpx;
  height: 44rpx;
  font-size: 34rpx;
  line-height: 38rpx;
}

.clear-btn {
  margin-top: 20rpx;
}

.extra {
  margin-top: 14rpx;
}

.empty-text {
  padding: 22rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(242, 240, 228, .06);
  background: rgba(7, 8, 14, .34);
  color: rgba(242, 240, 228, .62);
  font-size: 25rpx;
  line-height: 1.65;
}
