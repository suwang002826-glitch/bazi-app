<view class="page liuyao-page">
  <x-pattern />

  <view class="tool-title-hero">
    <view class="tool-title">六爻</view>
    <view class="tool-subtitle">一事一问 · 纳甲起卦</view>
    <view class="tool-stamp">起卦</view>
  </view>

  <view class="section cast-panel">
    <view class="section-kicker">一事一问</view>
    <view class="section-title">问事与起卦</view>
    <view class="field">
      <text class="label">所问事项</text>
      <textarea placeholder="例如：这件事下一步适合如何推进？" value="{{question}}" bindinput="onQuestionInput" />
    </view>
    <view class="ritual-panel">
      <view class="ritual-title">起卦前</view>
      <view class="ritual-row" wx:for="{{ritualItems}}" wx:key="*this">
        <text class="ritual-dot"></text>
        <text>{{item}}</text>
      </view>
    </view>
    <view class="mode-tabs">
      <view
        class="mode-tab {{modeIndex === index ? 'active' : ''}}"
        wx:for="{{modeOptions}}"
        wx:key="*this"
        bindtap="onModeChange"
        data-index="{{index}}"
      >{{item}}</view>
    </view>
    <view class="field">
      <text class="label">问题分类</text>
      <picker mode="selector" range="{{categoryOptions}}" value="{{categoryIndex}}" bindchange="onCategoryChange">
        <view>{{categoryOptions[categoryIndex]}}</view>
      </picker>
    </view>

    <view wx:if="{{modeIndex === 0}}" class="cast-mode-panel">
      <view class="manual-progress">
        <text>已成 {{lines.length}} / 6 爻</text>
        <text>静心点击六次，满六爻自动成卦</text>
      </view>
      <view wx:if="{{linePreviews.length}}" class="line-preview-row">
        <text wx:for="{{linePreviews}}" wx:key="position">{{item.position}} {{item.text}}</text>
      </view>
      <button class="primary cast-primary" bindtap="addManualLine">{{lines.length >= 6 ? '查看卦象' : '点爻'}}</button>
    </view>
    <view wx:elif="{{modeIndex === 1}}" class="cast-mode-panel">
      <view class="mode-note">
        <text>当前时间</text>
        <text>{{currentTimeLabel}}</text>
      </view>
      <button class="primary cast-primary" bindtap="castByCurrentTime">按当前时间起卦</button>
    </view>
    <view wx:else class="cast-mode-panel">
      <view class="field number-field">
        <text class="label">起卦数字</text>
        <input type="number" placeholder="请输入一组数字" value="{{numberSeed}}" bindinput="onNumberSeedInput" />
      </view>
      <button class="primary cast-primary" bindtap="castByNumber">按数字起卦</button>
    </view>
    <view class="cast-actions">
      <button class="secondary reset-btn" bindtap="resetCast">重新起卦</button>
    </view>
  </view>

</view>
