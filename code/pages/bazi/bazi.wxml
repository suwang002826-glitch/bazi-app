<view class="page bazi-page">
  <view class="bazi-hero">
    <view class="hero-cloud hero-cloud-left"></view>
    <view class="hero-cloud hero-cloud-right"></view>
    <view class="hero-title">八字排盘</view>
    <view class="hero-subtitle">道家命理 · 专业排盘</view>
    <view class="hero-stamp">小周神算</view>
  </view>

  <view class="entry-card">
    <view class="entry-card-head">
      <view>
        <view class="form-kicker">出生信息</view>
        <view class="form-title">生成八字盘</view>
      </view>
      <view class="form-badge">{{form.isLunar ? '农历模式' : '公历模式'}}</view>
    </view>

    <view class="entry-row name-row">
      <text class="entry-label">姓名</text>
      <input class="entry-input" placeholder="请输入姓名（必填）" value="{{form.name}}" bindinput="onNameInput" />
    </view>

    <view class="entry-row segmented-row">
      <view class="segmented-control">
        <view
          class="segment {{form.gender === item ? 'active' : ''}}"
          wx:for="{{genderOptions}}"
          wx:key="*this"
          bindtap="onGenderTap"
          data-gender="{{item}}"
        >{{item}}</view>
      </view>

      <view class="segmented-control calendar-control">
        <view
          class="segment {{activeCalendarMode === item ? 'active' : ''}}"
          wx:for="{{calendarModes}}"
          wx:key="*this"
          bindtap="onCalendarModeTap"
          data-mode="{{item}}"
        >{{item}}</view>
      </view>
    </view>

    <view wx:if="{{!form.isLunar}}" class="entry-row picker-row">
      <view>
        <text class="entry-label">公历生日</text>
        <text class="entry-hint">请选择公历年月日</text>
      </view>
      <picker mode="date" value="{{form.birthDate}}" bindchange="onDateChange">
        <view class="picker-value">{{form.birthDate}}</view>
      </picker>
      <text class="row-symbol">›</text>
    </view>

    <view wx:if="{{form.isLunar}}" class="entry-row picker-row lunar-picker-row">
      <view>
        <text class="entry-label">农历生日</text>
        <text class="entry-hint">{{lunarCoverageText}}</text>
      </view>
      <picker
        mode="multiSelector"
        range="{{lunarPickerRange}}"
        value="{{lunarPickerValue}}"
        bindcolumnchange="onLunarPickerColumnChange"
        bindchange="onLunarPickerChange"
      >
        <view class="picker-value lunar-picker-value">{{form.lunarYearMonthDayText}}</view>
      </picker>
      <text class="row-symbol">›</text>
    </view>

    <view class="entry-row picker-row">
      <view>
        <text class="entry-label">出生时辰</text>
        <text class="entry-hint">请选择出生时间</text>
      </view>
      <picker mode="time" value="{{form.birthTime}}" bindchange="onTimeChange">
        <view class="picker-value">{{form.birthTime}}</view>
      </picker>
      <text class="row-symbol">›</text>
    </view>

    <view class="entry-row picker-row">
      <text class="entry-label">出生地点</text>
      <picker mode="region" value="{{form.region}}" bindchange="onRegionChange">
        <view class="picker-value">{{form.regionText}}</view>
      </picker>
      <text class="row-symbol">›</text>
    </view>

    <view class="entry-row picker-row city-quick-row">
      <view>
        <text class="entry-label">快捷城市</text>
        <text class="entry-hint">用于真太阳时经纬度</text>
      </view>
      <picker mode="selector" range="{{cityPickerNames}}" value="{{cityPickerValue}}" bindchange="onCityPickerChange">
        <view class="picker-value city-picker-value">{{selectedCityPickerText}}</view>
      </picker>
      <text class="row-symbol">›</text>
    </view>

    <view class="entry-row">
      <view>
        <text class="entry-label">农历输入</text>
        <text class="entry-hint">{{form.isLunar ? '已开启' : '未开启（仅公历）'}}</text>
      </view>
      <view class="switch-column">
        <view class="option-switch">
          <text>农历日期</text>
          <switch checked="{{form.isLunar}}" bindchange="onLunarSwitch" color="#e8c98a" />
        </view>
      </view>
    </view>

    <view class="entry-row">
      <view>
        <text class="entry-label">时辰修正</text>
        <text class="entry-hint">真太阳时默认按出生地经纬度推算</text>
      </view>
    </view>

    <view class="solar-row">
      <view>
        <view wx:if="{{form.isLunar}}">农历生日：{{form.lunarYearMonthDayText}} {{form.birthTime}}</view>
        <view wx:else>公历生日：{{form.birthDate}} {{form.birthTime}}</view>
        <view>出生地经纬：北纬{{form.latitude}} 东经{{form.longitude}}</view>
        <view wx:if="{{form.locationSource}}">坐标来源：{{form.locationSource}}</view>
        <view>真太阳时：{{form.useTrueSolarTime ? '开启' : '关闭'}}</view>
        <view>早晚子时：{{form.useEarlyLateZi ? '开启' : '关闭'}}</view>
      </view>
      <view class="switch-column">
        <view class="option-switch">
          <text>真太阳时</text>
          <switch checked="{{form.useTrueSolarTime}}" bindchange="onTrueSolarSwitch" color="#e8c98a" />
        </view>
        <view class="option-switch">
          <text>早晚子时</text>
          <switch checked="{{form.useEarlyLateZi}}" bindchange="onEarlyLateZiSwitch" color="#e8c98a" />
        </view>
      </view>
    </view>

    <button class="start-button" loading="{{isGenerating}}" disabled="{{isGenerating}}" bindtap="generateReading">开始排盘</button>
    <view class="start-helper">请尽量使用准确出生时间与出生地，经度会影响真太阳时修正。</view>
  </view>
</view>
