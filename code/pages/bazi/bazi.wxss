.bazi-page {
  min-height: 100vh;
  padding: 0 32rpx calc(40rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #07080e 0%, #101127 54%, #07080e 100%);
  color: #f2f0e4;
}

.bazi-hero {
  position: relative;
  min-height: 300rpx;
  padding-top: calc(76rpx + env(safe-area-inset-top));
  text-align: center;
}

.hero-title {
  position: relative;
  z-index: 1;
  color: #f2f0e4;
  font-family: "Songti SC", "STSong", "SimSun", serif;
  font-size: 64rpx;
  font-weight: 900;
  letter-spacing: 8rpx;
  line-height: 1.08;
}

.hero-subtitle {
  position: relative;
  z-index: 1;
  margin-top: 24rpx;
  color: rgba(242, 240, 228, .62);
  font-size: 28rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
}

.hero-stamp {
  position: absolute;
  z-index: 1;
  top: calc(92rpx + env(safe-area-inset-top));
  right: 112rpx;
  width: 40rpx;
  height: 50rpx;
  border: 2rpx solid rgba(217, 191, 113, .34);
  color: #d9bf71;
  font-size: 18rpx;
  font-weight: 900;
  line-height: 23rpx;
  text-align: center;
}

.hero-cloud {
  display: none;
}

.hero-cloud-left {
  top: calc(98rpx + env(safe-area-inset-top));
  left: 36rpx;
}

.hero-cloud-right {
  top: calc(128rpx + env(safe-area-inset-top));
  right: 38rpx;
}

.entry-card {
  position: relative;
  z-index: 2;
  margin-top: -16rpx;
  padding: 16rpx 30rpx 30rpx;
  border: 1rpx solid rgba(217, 191, 113, .16);
  border-radius: 22rpx;
  background:
    linear-gradient(145deg, rgba(242, 240, 228, .10), rgba(242, 240, 228, .035)),
    rgba(18, 21, 50, .92);
  box-shadow:
    inset 0 1rpx 0 rgba(242, 240, 228, .10),
    0 26rpx 56rpx rgba(0, 0, 0, .32);
}

.entry-row {
  min-height: 108rpx;
  border-bottom: 1rpx solid rgba(242, 240, 228, .10);
}

.entry-row:last-of-type {
  border-bottom: 0;
}

.name-row,
.picker-row,
.segmented-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.entry-label {
  flex: 0 0 auto;
  color: #f2f0e4;
  font-size: 32rpx;
  font-weight: 800;
}

.entry-hint {
  margin-left: 6rpx;
  color: rgba(242, 240, 228, .44);
  font-size: 22rpx;
}

.entry-input {
  height: 100rpx;
  min-width: 0;
  flex: 1;
  padding: 0;
  border: 0;
  background: transparent;
  color: #f2f0e4;
  font-size: 30rpx;
  line-height: 100rpx;
  text-align: right;
  box-shadow: none;
}

.entry-input input-placeholder {
  color: rgba(242, 240, 228, .34);
}

.row-symbol {
  flex: 0 0 auto;
  width: 46rpx;
  color: rgba(217, 191, 113, .62);
  font-size: 34rpx;
  text-align: right;
}

.segmented-row {
  padding: 22rpx 0;
}

.segmented-control {
  display: flex;
  min-width: 210rpx;
  height: 66rpx;
  padding: 4rpx;
  border: 1rpx solid rgba(217, 191, 113, .18);
  border-radius: 18rpx;
  background: rgba(7, 8, 14, .34);
}

.calendar-control {
  min-width: 312rpx;
}

.segment {
  flex: 1;
  min-width: 0;
  border-radius: 14rpx;
  color: rgba(242, 240, 228, .58);
  font-size: 29rpx;
  line-height: 56rpx;
  text-align: center;
}

.segment.active {
  background: #d9bf71;
  color: #222559;
  font-weight: 900;
  box-shadow: 0 6rpx 14rpx rgba(0, 0, 0, .20);
}

.picker-row {
  padding: 6rpx 0;
}

.picker-row picker {
  width: auto;
  height: auto;
  padding: 0;
  border: 0;
  background: transparent;
  box-shadow: none;
}

.picker-value {
  max-width: 410rpx;
  overflow: hidden;
  color: #f2f0e4;
  font-size: 30rpx;
  line-height: 1.45;
  text-align: right;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dual-picker {
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
}

.dual-picker picker {
  color: #f2f0e4;
  font-size: 30rpx;
}

.solar-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 28rpx 0 24rpx;
  color: rgba(242, 240, 228, .66);
  font-size: 24rpx;
  line-height: 1.65;
}

.save-switch {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  gap: 8rpx;
  color: #f2f0e4;
  font-size: 28rpx;
  font-weight: 800;
}

.start-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  margin-top: 16rpx;
  padding: 0;
  border-radius: 14rpx;
  background:
    linear-gradient(90deg, rgba(217, 191, 113, .95), rgba(242, 240, 228, .88));
  color: #222559;
  font-family: "Songti SC", "STSong", "SimSun", serif;
  font-size: 38rpx;
  font-weight: 900;
  letter-spacing: 4rpx;
  line-height: normal;
  box-shadow: 0 18rpx 34rpx rgba(0, 0, 0, .26);
}

.start-button:active {
  transform: translateY(1rpx);
}
