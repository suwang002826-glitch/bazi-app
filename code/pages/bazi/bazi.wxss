.bazi-page {
  min-height: 100vh;
  padding: 0 32rpx calc(40rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 92% 14%, rgba(217, 191, 113, .18), transparent 28%),
    radial-gradient(circle at 10% 0%, rgba(159, 136, 191, .24), transparent 30%),
    linear-gradient(180deg, #f2f0e4 0%, #ece8dc 100%);
  color: #222559;
}

.bazi-hero {
  position: relative;
  min-height: 300rpx;
  padding-top: calc(76rpx + env(safe-area-inset-top));
  text-align: center;
}

.bazi-hero::after {
  position: absolute;
  right: -38rpx;
  bottom: 10rpx;
  width: 206rpx;
  height: 206rpx;
  border: 18rpx solid rgba(70, 59, 140, .045);
  border-radius: 50%;
  content: "";
}

.hero-title {
  position: relative;
  z-index: 1;
  color: #222559;
  font-family: "Songti SC", "SimSun", "Kaiti SC", serif;
  font-size: 64rpx;
  font-weight: 900;
  letter-spacing: 8rpx;
  line-height: 1.08;
}

.hero-subtitle {
  position: relative;
  z-index: 1;
  margin-top: 24rpx;
  color: rgba(34, 37, 89, .58);
  font-size: 28rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
}

.hero-stamp {
  position: absolute;
  z-index: 1;
  top: calc(92rpx + env(safe-area-inset-top));
  right: 112rpx;
  width: 40rpx;
  height: 50rpx;
  border: 2rpx solid rgba(143, 42, 38, .42);
  color: #8f2a26;
  font-size: 18rpx;
  font-weight: 900;
  line-height: 23rpx;
  text-align: center;
}

.hero-cloud {
  position: absolute;
  width: 124rpx;
  height: 30rpx;
  border-top: 3rpx solid rgba(217, 191, 113, .32);
  border-bottom: 3rpx solid rgba(217, 191, 113, .15);
  border-radius: 999rpx;
}

.hero-cloud-left {
  top: calc(98rpx + env(safe-area-inset-top));
  left: 36rpx;
}

.hero-cloud-right {
  top: calc(128rpx + env(safe-area-inset-top));
  right: 38rpx;
}

.entry-card {
  position: relative;
  z-index: 2;
  margin-top: -16rpx;
  padding: 16rpx 30rpx 30rpx;
  border: 1rpx solid rgba(70, 59, 140, .12);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, .72);
  box-shadow: 0 22rpx 54rpx rgba(34, 37, 89, .12);
}

.entry-row {
  min-height: 108rpx;
  border-bottom: 1rpx solid rgba(34, 37, 89, .11);
}

.entry-row:last-of-type {
  border-bottom: 0;
}

.name-row,
.picker-row,
.segmented-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.entry-label {
  flex: 0 0 auto;
  color: #222559;
  font-size: 32rpx;
  font-weight: 800;
}

.entry-hint {
  margin-left: 6rpx;
  color: rgba(34, 37, 89, .44);
  font-size: 22rpx;
}

.entry-input {
  height: 100rpx;
  min-width: 0;
  flex: 1;
  padding: 0;
  border: 0;
  background: transparent;
  color: #222559;
  font-size: 30rpx;
  line-height: 100rpx;
  text-align: right;
  box-shadow: none;
}

.entry-input input-placeholder {
  color: rgba(34, 37, 89, .35);
}

.row-symbol {
  flex: 0 0 auto;
  width: 46rpx;
  color: rgba(34, 37, 89, .50);
  font-size: 34rpx;
  text-align: right;
}

.segmented-row {
  padding: 22rpx 0;
}

.segmented-control {
  display: flex;
  min-width: 210rpx;
  height: 66rpx;
  padding: 4rpx;
  border: 1rpx solid rgba(70, 59, 140, .26);
  border-radius: 18rpx;
  background: rgba(255, 255, 255, .42);
}

.calendar-control {
  min-width: 312rpx;
}

.segment {
  flex: 1;
  min-width: 0;
  border-radius: 14rpx;
  color: rgba(34, 37, 89, .62);
  font-size: 29rpx;
  line-height: 56rpx;
  text-align: center;
}

.segment.active {
  background: #f2f0e4;
  color: #463b8c;
  font-weight: 900;
  box-shadow: inset 0 0 0 2rpx rgba(70, 59, 140, .16);
}

.picker-row {
  padding: 6rpx 0;
}

.picker-row picker {
  width: auto;
  height: auto;
  padding: 0;
  border: 0;
  background: transparent;
  box-shadow: none;
}

.picker-value {
  max-width: 410rpx;
  overflow: hidden;
  color: #222559;
  font-size: 30rpx;
  line-height: 1.45;
  text-align: right;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dual-picker {
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
}

.dual-picker picker {
  color: #222559;
  font-size: 30rpx;
}

.solar-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 28rpx 0 24rpx;
  color: rgba(34, 37, 89, .70);
  font-size: 24rpx;
  line-height: 1.65;
}

.save-switch {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  gap: 8rpx;
  color: #222559;
  font-size: 28rpx;
  font-weight: 800;
}

.start-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  margin-top: 16rpx;
  padding: 0;
  border-radius: 16rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, .08), transparent),
    #222559;
  color: #d9bf71;
  font-family: "Songti SC", "SimSun", "Kaiti SC", serif;
  font-size: 38rpx;
  font-weight: 900;
  letter-spacing: 4rpx;
  line-height: normal;
  box-shadow: 0 16rpx 32rpx rgba(34, 37, 89, .22);
}

.start-button:active {
  transform: translateY(1rpx);
}
