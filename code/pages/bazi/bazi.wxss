.bazi-page {
  min-height: 100vh;
  padding: 0 24rpx calc(36rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 86% 4%, rgba(159, 136, 191, .26), transparent 34%),
    linear-gradient(180deg, #222559 0%, #463b8c 44%, #f2f0e4 44%, #ece8dc 100%);
  color: #222559;
}

.bazi-topbar {
  display: grid;
  grid-template-columns: 72rpx 1fr 72rpx;
  align-items: center;
  height: calc(132rpx + env(safe-area-inset-top));
  padding-top: calc(24rpx + env(safe-area-inset-top));
  border-bottom: 1rpx solid rgba(242, 240, 228, .12);
}

.top-title {
  color: #f2f0e4;
  font-size: 36rpx;
  font-weight: 500;
  text-align: center;
}

.top-icon {
  color: #f2f0e4;
  font-size: 34rpx;
  text-align: center;
}

.entry-card {
  margin-top: 38rpx;
  padding: 28rpx 32rpx;
  border: 1rpx solid rgba(70, 59, 140, .14);
  border-radius: 14rpx;
  background: rgba(242, 240, 228, .96);
  box-shadow: 0 18rpx 42rpx rgba(34, 37, 89, .16);
}

.entry-row {
  min-height: 104rpx;
  border-bottom: 1rpx solid rgba(70, 59, 140, .12);
}

.entry-row:last-of-type {
  border-bottom: 0;
}

.name-row,
.picker-row,
.segmented-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.entry-label {
  flex: 0 0 auto;
  color: #222559;
  font-size: 31rpx;
  font-weight: 500;
}

.entry-hint {
  margin-left: 6rpx;
  color: rgba(34, 37, 89, .50);
  font-size: 22rpx;
}

.entry-input {
  height: 98rpx;
  padding: 0;
  border: 0;
  background: transparent;
  color: #222559;
  font-size: 31rpx;
  line-height: 98rpx;
  text-align: right;
  box-shadow: none;
}

.entry-input input-placeholder {
  color: rgba(34, 37, 89, .42);
}

.segmented-row {
  padding: 20rpx 0;
}

.segmented-control {
  display: flex;
  min-width: 210rpx;
  height: 62rpx;
  padding: 6rpx;
  border: 1rpx solid rgba(70, 59, 140, .14);
  border-radius: 999rpx;
  background: rgba(70, 59, 140, .08);
}

.calendar-control {
  min-width: 300rpx;
}

.segment {
  flex: 1;
  min-width: 0;
  border-radius: 999rpx;
  color: rgba(34, 37, 89, .56);
  font-size: 28rpx;
  line-height: 50rpx;
  text-align: center;
}

.segment.active {
  background: #d9bf71;
  color: #222559;
  font-weight: 800;
}

.picker-row {
  padding: 6rpx 0;
}

.picker-row picker {
  width: auto;
  height: auto;
  padding: 0;
  border: 0;
  background: transparent;
  box-shadow: none;
}

.picker-value {
  max-width: 420rpx;
  overflow: hidden;
  color: #222559;
  font-size: 30rpx;
  line-height: 1.45;
  text-align: right;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dual-picker {
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
}

.dual-picker picker {
  color: #222559;
  font-size: 30rpx;
}

.solar-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 28rpx 0 24rpx;
  color: rgba(34, 37, 89, .72);
  font-size: 25rpx;
  line-height: 1.65;
}

.save-switch {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  gap: 10rpx;
  color: #222559;
  font-size: 30rpx;
}

.start-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  margin-top: 22rpx;
  padding: 0;
  border-radius: 999rpx;
  background: #222559;
  color: #f2f0e4;
  font-size: 34rpx;
  font-weight: 900;
  line-height: normal;
}
