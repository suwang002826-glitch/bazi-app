page {
  min-height: 100%;
  background: #07080e;
  color: #f2f0e4;
  font-family: "KaiTi", "STKaiti", "Kaiti SC", "楷体", "SimKai", serif;
}

view,
text,
input,
picker,
textarea,
button {
  box-sizing: border-box;
  font-family: "KaiTi", "STKaiti", "Kaiti SC", "楷体", "SimKai", serif;
}

.hero-title,
.seal,
.avatar,
.day-master,
.qimen-seal,
.focus-seal,
.section-title {
  font-family: "KaiTi", "STKaiti", "Kaiti SC", "楷体", "SimKai", serif;
}

.page {
  position: relative;
  z-index: 1;
  min-height: 100vh;
  padding: 24rpx 22rpx calc(42rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #07080e 0%, #101127 54%, #07080e 100%);
}

.section {
  position: relative;
  z-index: 1;
  margin-bottom: 22rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(217, 191, 113, .14);
  border-radius: 16rpx;
  background: linear-gradient(145deg, rgba(242, 240, 228, .075), rgba(242, 240, 228, .025)), rgba(18, 21, 50, .92);
  box-shadow: inset 0 1rpx 0 rgba(242, 240, 228, .08), 0 8rpx 16rpx rgba(0, 0, 0, .22);
}

.section-title {
  margin-bottom: 14rpx;
  color: #f2f0e4;
  font-size: 32rpx;
  font-weight: 800;
  letter-spacing: 0;
  line-height: 1.25;
}

.section-kicker {
  display: inline-flex;
  margin-bottom: 12rpx;
  padding: 5rpx 12rpx;
  border: 1rpx solid rgba(217, 191, 113, .20);
  border-radius: 999rpx;
  background: rgba(217, 191, 113, .10);
  color: #d9bf71;
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 0;
  line-height: 1.35;
}

.muted {
  color: rgba(242, 240, 228, .66);
  font-size: 26rpx;
  line-height: 1.65;
}

.field {
  margin-bottom: 22rpx;
}

.label {
  display: block;
  margin-bottom: 10rpx;
  color: #f2f0e4;
  font-size: 25rpx;
  font-weight: 800;
}

input,
picker,
textarea {
  width: 100%;
  border: 1rpx solid rgba(217, 191, 113, .14);
  border-radius: 12rpx;
  background: rgba(7, 8, 14, .46);
  color: #f2f0e4;
  font-size: 29rpx;
  box-shadow: inset 0 1rpx 0 rgba(242, 240, 228, .06);
}

input,
picker {
  height: 82rpx;
  padding: 0 22rpx;
  line-height: 82rpx;
}

textarea {
  min-height: 144rpx;
  padding: 18rpx 22rpx;
  line-height: 1.55;
}

button {
  min-height: 78rpx;
  margin: 0;
  border-radius: 10rpx;
  font-size: 28rpx;
  font-weight: 800;
}

button::after {
  border: 0;
}

button.primary {
  margin-top: 16rpx;
  border: 1rpx solid rgba(217, 191, 113, .28);
  background: #d9bf71;
  color: #222559;
  line-height: 86rpx;
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, .20);
}

button.primary:active {
  background: #c9ad60;
  transform: translateY(1rpx);
}

button.secondary {
  border: 1rpx solid rgba(217, 191, 113, .16);
  background: rgba(242, 240, 228, .055);
  color: #f2f0e4;
  line-height: 76rpx;
}

button.secondary:active {
  background: rgba(217, 191, 113, .18);
}

button[disabled] {
  opacity: .48;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  max-width: 100%;
  padding: 8rpx 16rpx;
  border: 1rpx solid rgba(217, 191, 113, .14);
  border-radius: 999rpx;
  background: rgba(70, 59, 140, .16);
  color: #d9bf71;
  font-size: 24rpx;
  font-weight: 700;
}

.result-card {
  margin-top: 22rpx;
  padding: 22rpx;
  border: 1rpx solid rgba(217, 191, 113, .14);
  border-radius: 16rpx;
  background: rgba(18, 21, 50, .88);
}

.result-line {
  margin-bottom: 12rpx;
  color: rgba(242, 240, 228, .76);
  font-size: 27rpx;
  line-height: 1.68;
}

.disclaimer {
  margin-top: 18rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(217, 191, 113, .16);
  border-radius: 14rpx;
  background: rgba(217, 191, 113, .08);
  color: rgba(242, 240, 228, .72);
  font-size: 24rpx;
  line-height: 1.68;
}
