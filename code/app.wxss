page {
  min-height: 100%;
  background: #f2f0e4;
  color: #222559;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

view,
text,
input,
picker,
textarea,
button {
  box-sizing: border-box;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.hero-title,
.seal,
.avatar,
.day-master,
.qimen-seal,
.focus-seal,
.section-title {
  font-family: "Songti SC", "SimSun", "Kaiti SC", "STKaiti", "KaiTi", serif;
}

.page {
  position: relative;
  z-index: 1;
  min-height: 100vh;
  padding: 24rpx 22rpx calc(42rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 88% 2%, rgba(159, 136, 191, .18), transparent 30%),
    radial-gradient(circle at 6% 14%, rgba(217, 191, 113, .14), transparent 34%),
    linear-gradient(180deg, #222559 0%, #463b8c 42%, #f2f0e4 42%, #ece8dc 100%);
}

.section {
  position: relative;
  z-index: 1;
  margin-bottom: 22rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(70, 59, 140, .14);
  border-radius: 12rpx;
  background: rgba(242, 240, 228, .94);
  box-shadow: 0 10rpx 24rpx rgba(34, 37, 89, .08);
}

.section-title {
  margin-bottom: 14rpx;
  color: #222559;
  font-size: 32rpx;
  font-weight: 800;
  letter-spacing: 0;
  line-height: 1.25;
}

.section-kicker {
  display: inline-flex;
  margin-bottom: 12rpx;
  padding: 5rpx 12rpx;
  border: 1rpx solid rgba(70, 59, 140, .14);
  border-radius: 999rpx;
  background: rgba(70, 59, 140, .08);
  color: #463b8c;
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 0;
  line-height: 1.35;
}

.muted {
  color: rgba(34, 37, 89, .72);
  font-size: 26rpx;
  line-height: 1.65;
}

.field {
  margin-bottom: 22rpx;
}

.label {
  display: block;
  margin-bottom: 10rpx;
  color: #222559;
  font-size: 25rpx;
  font-weight: 800;
}

input,
picker,
textarea {
  width: 100%;
  border: 1rpx solid rgba(70, 59, 140, .18);
  border-radius: 10rpx;
  background: rgba(255, 255, 255, .90);
  color: #222559;
  font-size: 29rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, .78);
}

input,
picker {
  height: 82rpx;
  padding: 0 22rpx;
  line-height: 82rpx;
}

textarea {
  min-height: 144rpx;
  padding: 18rpx 22rpx;
  line-height: 1.55;
}

button {
  min-height: 78rpx;
  margin: 0;
  border-radius: 10rpx;
  font-size: 28rpx;
  font-weight: 800;
}

button::after {
  border: 0;
}

button.primary {
  margin-top: 16rpx;
  border: 1rpx solid rgba(34, 37, 89, .28);
  background: #222559;
  color: #f2f0e4;
  line-height: 86rpx;
  box-shadow: 0 8rpx 18rpx rgba(34, 37, 89, .16);
}

button.primary:active {
  background: #463b8c;
  transform: translateY(1rpx);
}

button.secondary {
  border: 1rpx solid rgba(70, 59, 140, .20);
  background: rgba(242, 240, 228, .88);
  color: #222559;
  line-height: 76rpx;
}

button.secondary:active {
  background: rgba(217, 191, 113, .18);
}

button[disabled] {
  opacity: .48;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  max-width: 100%;
  padding: 8rpx 16rpx;
  border: 1rpx solid rgba(70, 59, 140, .16);
  border-radius: 999rpx;
  background: rgba(70, 59, 140, .08);
  color: #463b8c;
  font-size: 24rpx;
  font-weight: 700;
}

.result-card {
  margin-top: 22rpx;
  padding: 22rpx;
  border: 1rpx solid rgba(70, 59, 140, .16);
  border-radius: 12rpx;
  background: rgba(242, 240, 228, .88);
}

.result-line {
  margin-bottom: 12rpx;
  color: #222559;
  font-size: 27rpx;
  line-height: 1.68;
}

.disclaimer {
  margin-top: 18rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(126, 98, 42, .22);
  border-radius: 14rpx;
  background: rgba(250, 246, 232, .72);
  color: #59451d;
  font-size: 24rpx;
  line-height: 1.68;
}
